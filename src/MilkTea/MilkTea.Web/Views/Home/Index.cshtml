@{
    ViewData["Title"] = "Trang chủ";
}

<section class="hero-section">
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1>Trà sữa ngon<br />Uống là mê!</h1>
                <p>Nguyên liệu chất lượng – Hương vị tuyệt hảo</p>
                <a href="#" class="hero-button">Mua ngay</a>
            </div>

            <div class="hero-image-placeholder">
                <span>Ảnh ly trà sữa</span>
            </div>
        </div>
    </div>
</section>
<section class="feature-section">

    <div class="container">

        <div class="row g-4">

            <div class="col-md-4">

                <div class="feature-card">

                    <i class="bi bi-box-seam feature-icon"></i>

                    <h4>Nguyên liệu chất lượng</h4>

                    <p>Chọn lọc kỹ càng từ những nhà cung cấp uy tín.</p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="feature-card">

                    <i class="bi bi-cup-hot feature-icon"></i>

                    <h4>Pha chế chuẩn vị</h4>

                    <p>Đậm đà hương vị, công thức độc quyền.</p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="feature-card">

                    <i class="bi bi-truck feature-icon"></i>

                    <h4>Giao hàng nhanh</h4>

                    <p>Nhanh chóng - An toàn - Đúng giờ.</p>

                </div>

            </div>

        </div>

    </div>

</section>

    <section class="featured-products">

        <div class="container">

            <div class="section-heading">
               
                <h2>Sản phẩm nổi bật</h2>

                <a href="#">Xem tất cả →</a>

            </div>

            <!-- Card sản phẩm sẽ đặt ở đây -->
            <div class="product-list">

            </div>
        </div>

    </section>
@model List<MilkTea.Web.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ";
}

<section class="landing-hero">

    <div id="milkTeaLandingHero"
         class="carousel slide"
         data-bs-ride="carousel"
         data-bs-interval="3800">

        <div class="carousel-indicators hero-indicators">
            <button type="button"
                    data-bs-target="#milkTeaLandingHero"
                    data-bs-slide-to="0"
                    class="active">
            </button>

            <button type="button"
                    data-bs-target="#milkTeaLandingHero"
                    data-bs-slide-to="1">
            </button>

            <button type="button"
                    data-bs-target="#milkTeaLandingHero"
                    data-bs-slide-to="2">
            </button>
        </div>

        <div class="carousel-inner">

            <!-- SLIDE 1 -->
            <div class="carousel-item active">

                <div class="hero-container">

                    <div class="hero-left">

                        <div class="hero-badge">
                            <i class="bi bi-star-fill"></i>
                            BEST SELLER
                        </div>

                        <h1>
                            Trà sữa ngon<br />
                            Uống là mê!
                        </h1>

                        <p class="hero-desc">
                            Nguyên liệu tuyển chọn, hương vị đậm đà,
                            topping tươi ngon. Mang đến trải nghiệm
                            trà sữa trọn vẹn mỗi ngày.
                        </p>

                        <div class="hero-highlights">

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-flower1"></i>
                                </span>

                                <strong>
                                    Matcha<br />
                                    Nhật Bản
                                </strong>
                            </div>

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-droplet-fill"></i>
                                </span>

                                <strong>
                                    Trân châu<br />
                                    tươi
                                </strong>
                            </div>

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-truck"></i>
                                </span>

                                <strong>
                                    Giao nhanh<br />
                                    30 phút
                                </strong>
                            </div>

                        </div>

                        <div class="hero-actions">

                            <a href="#products"
                               class="btn-hero primary">

                                <i class="bi bi-bag-heart"></i>
                                Đặt ngay
                            </a>

                            <a asp-controller="SanPham"
                               asp-action="Index"
                               class="btn-hero secondary">

                                <i class="bi bi-card-list"></i>
                                Xem menu
                            </a>

                        </div>

                    </div>

                    <div class="hero-right">

                        <div class="milk-splash"></div>

                        <img src="~/images/products/tra-sua-duong-den.png"
                             alt="Trà sữa đường đen"
                             class="hero-main-drink" />

                        <img src="~/images/products/tra-sua-matcha.png"
                             alt="Trà sữa Matcha"
                             class="hero-second-drink" />

                        <div class="bubble b1"></div>
                        <div class="bubble b2"></div>
                        <div class="bubble b3"></div>

                    </div>

                </div>

            </div>

            <!-- SLIDE 2 -->
            <div class="carousel-item">

                <div class="hero-container">

                    <div class="hero-left">

                        <div class="hero-badge sale">
                            <i class="bi bi-gift-fill"></i>
                            KHUYẾN MÃI
                        </div>

                        <h1>
                            Mua 2 ly<br />
                            Tặng ngay 1!
                        </h1>

                        <p class="hero-desc">
                            Ưu đãi hấp dẫn dành cho các món trà sữa bán chạy.
                            Áp dụng trong tuần này tại MilkTea House.
                        </p>

                        <div class="hero-highlights">

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-fire"></i>
                                </span>

                                <strong>
                                    Ưu đãi<br />
                                    hấp dẫn
                                </strong>
                            </div>

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-cup-straw"></i>
                                </span>

                                <strong>
                                    Toàn bộ<br />
                                    menu
                                </strong>
                            </div>

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-clock"></i>
                                </span>

                                <strong>
                                    Số lượng<br />
                                    có hạn
                                </strong>
                            </div>

                        </div>

                        <div class="hero-actions">

                            <a href="#products"
                               class="btn-hero primary">

                                <i class="bi bi-gift"></i>
                                Nhận ưu đãi
                            </a>

                            <a asp-controller="SanPham"
                               asp-action="Index"
                               class="btn-hero secondary">

                                <i class="bi bi-card-list"></i>
                                Xem chi tiết
                            </a>

                        </div>

                    </div>

                    <div class="hero-right">

                        <div class="milk-splash"></div>

                        <img src="~/images/products/tra-sua-socola.png"
                             alt="Trà sữa Socola"
                             class="hero-main-drink" />

                        <img src="~/images/products/tra-sua-duong-den.png"
                             alt="Trà sữa đường đen"
                             class="hero-second-drink" />

                        <div class="bubble b1"></div>
                        <div class="bubble b2"></div>
                        <div class="bubble b3"></div>

                    </div>

                </div>

            </div>

            <!-- SLIDE 3 -->
            <div class="carousel-item">

                <div class="hero-container">

                    <div class="hero-left">

                        <div class="hero-badge brand">
                            <i class="bi bi-cup-hot-fill"></i>
                            MILKTEA HOUSE
                        </div>

                        <h1>
                            Nguyên liệu tốt<br />
                            Vị ngon chuẩn!
                        </h1>

                        <p class="hero-desc">
                            Từ trà, sữa đến topping đều được chọn lọc kỹ,
                            mang đến ly trà sữa thơm ngon và an toàn.
                        </p>

                        <div class="hero-highlights">

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-shield-check"></i>
                                </span>

                                <strong>
                                    An toàn<br />
                                    chất lượng
                                </strong>
                            </div>

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-heart-fill"></i>
                                </span>

                                <strong>
                                    Phục vụ<br />
                                    tận tâm
                                </strong>
                            </div>

                            <div class="hero-highlight-item">
                                <span>
                                    <i class="bi bi-stars"></i>
                                </span>

                                <strong>
                                    Hương vị<br />
                                    khó quên
                                </strong>
                            </div>

                        </div>

                        <div class="hero-actions">

                            <a href="#products"
                               class="btn-hero primary">

                                <i class="bi bi-search-heart"></i>
                                Khám phá
                            </a>

                            <a href="#"
                               class="btn-hero secondary">

                                <i class="bi bi-telephone"></i>
                                Liên hệ
                            </a>

                        </div>

                    </div>

                    <div class="hero-right">

                        <div class="milk-splash"></div>

                        <img src="~/images/products/tra-sua-matcha.png"
                             alt="Trà sữa Matcha"
                             class="hero-main-drink" />

                        <img src="~/images/products/tra-sua-truyen-thong.png"
                             alt="Trà sữa truyền thống"
                             class="hero-second-drink" />

                        <div class="bubble b1"></div>
                        <div class="bubble b2"></div>
                        <div class="bubble b3"></div>

                    </div>

                </div>

            </div>

        </div>

        <button class="carousel-control-prev hero-control-prev"
                type="button"
                data-bs-target="#milkTeaLandingHero"
                data-bs-slide="prev">

            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next hero-control-next"
                type="button"
                data-bs-target="#milkTeaLandingHero"
                data-bs-slide="next">

            <span class="carousel-control-next-icon"></span>
        </button>

    </div>

    <div class="hero-features-wrap">

        <div class="section-mini-title">
            <span></span>
            <h2>Vì sao chọn MilkTea House?</h2>
            <span></span>
        </div>

        <div class="hero-features">

            <div class="hero-feature-card">

                <div class="feature-round-icon">
                    <i class="bi bi-shield-check"></i>
                </div>

                <div class="hero-feature-text">
                    <h3>Nguyên liệu chất lượng</h3>

                    <p>
                        Tuyển chọn nguyên liệu tươi ngon,
                        an toàn cho sức khỏe.
                    </p>
                </div>

            </div>

            <div class="hero-feature-card">

                <div class="feature-round-icon">
                    <i class="bi bi-cup-hot"></i>
                </div>

                <div class="hero-feature-text">
                    <h3>Hương vị đặc trưng</h3>

                    <p>
                        Công thức độc quyền,
                        hương vị đậm đà, khó quên.
                    </p>
                </div>

            </div>

            <div class="hero-feature-card">

                <div class="feature-round-icon">
                    <i class="bi bi-truck"></i>
                </div>

                <div class="hero-feature-text">
                    <h3>Giao hàng nhanh chóng</h3>

                    <p>
                        Giao nhanh 30 phút
                        trong khu vực nội thành.
                    </p>
                </div>

            </div>

        </div>

    </div>

</section>

<section class="featured-products"
         id="products">

    <div class="product-container">

        <div class="product-section-header">

            <div class="center-heading">
                <span></span>
                <h2>Sản phẩm nổi bật</h2>
                <span></span>
            </div>

            <a asp-controller="SanPham"
               asp-action="Index"
               class="view-all-products">

                Xem tất cả
                <i class="bi bi-arrow-right"></i>
            </a>

        </div>

        @if (Model != null && Model.Count > 0)
        {
            <div class="product-list">

                @foreach (var item in Model)
                {
                    var tenHinhAnh =
                        (item.HinhAnh ?? string.Empty)
                        .Trim()
                        .Replace("\\", "/");

                    string duongDanHinhAnh;

                    if (string.IsNullOrWhiteSpace(tenHinhAnh))
                    {
                        duongDanHinhAnh =
                            "/images/products/tra-sua-truyen-thong.png";
                    }
                    else if (tenHinhAnh.StartsWith("~/"))
                    {
                        duongDanHinhAnh =
                            Url.Content(tenHinhAnh);
                    }
                    else if (tenHinhAnh.StartsWith("/"))
                    {
                        duongDanHinhAnh =
                            tenHinhAnh;
                    }
                    else if (tenHinhAnh.StartsWith("images/"))
                    {
                        duongDanHinhAnh =
                            "/" + tenHinhAnh;
                    }
                    else
                    {
                        duongDanHinhAnh =
                            "/images/products/" + tenHinhAnh;
                    }

                    <div class="product-card">

                        <div class="product-image">

                            @if (item.NhanSanPham == 1)
                            {
                                <span class="product-badge hot">
                                    <i class="bi bi-fire"></i>
                                    HOT
                                </span>
                            }
                            else if (item.NhanSanPham == 2)
                            {
                                <span class="product-badge new">
                                    NEW
                                </span>
                            }

                            <img src="@duongDanHinhAnh"
                                 alt="@item.TenSanPham"
                                 class="product-photo"
                                 loading="lazy"
                                 onerror="this.onerror=null; this.src='/images/products/tra-sua-truyen-thong.png';" />

                        </div>

                        <div class="product-info">

                            <h4>@item.TenSanPham</h4>

                            <div class="product-rating">

                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>

                                <span>
                                    (@item.DanhGia.ToString("0.00"))
                                </span>

                            </div>

                            <div class="product-price">

                                @if (item.GiaGoc.HasValue &&
                                     item.GiaGoc.Value > item.Gia)
                                {
                                    <span class="old-price">
                                        @item.GiaGoc.Value.ToString("N0")đ
                                    </span>
                                }

                                <span class="new-price">
                                    @item.Gia.ToString("N0")đ
                                </span>

                            </div>

                            <a href="#"
                               class="btn-add-cart">

                                <i class="bi bi-cart3"></i>
                                Thêm vào giỏ
                            </a>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="product-empty">
                Hiện chưa có sản phẩm nổi bật.
            </div>
        }

    </div>

</section>
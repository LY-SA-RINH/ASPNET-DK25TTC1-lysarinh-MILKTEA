@model List<MilkTea.Web.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ";
}

    <section class="hero-section">
    
        <div id="milkTeaHero" class="carousel slide" data-bs-ride="carousel">

            <div class="carousel-indicators">
                <button type="button" data-bs-target="#milkTeaHero" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#milkTeaHero" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#milkTeaHero" data-bs-slide-to="2"></button>
            </div>

            <div class="carousel-inner">

                <!-- HERO 1 -->
                <div class="carousel-item active">
                    <div class="hero-content hero-matcha">

                        <div class="hero-text">
                            <span class="hero-badge">🔥 BEST SELLER</span>

                            <h1>Trà sữa ngon<br />Uống là mê!</h1>

                            <p>
                                Matcha thơm béo, trân châu nấu mới mỗi ngày,
                                giao nhanh tận nơi chỉ trong 30 phút.
                            </p>

                            <div class="hero-features">
                                <span><i class="bi bi-check-circle-fill"></i> Matcha Nhật Bản</span>
                                <span><i class="bi bi-check-circle-fill"></i> Trân châu tươi</span>
                                <span><i class="bi bi-check-circle-fill"></i> Giao nhanh 30 phút</span>
                            </div>

                            <div class="hero-actions">
                                <a href="#" class="hero-button primary">
                                    <i class="bi bi-cart-plus"></i>
                                    Đặt ngay
                                </a>

                                <a href="#" class="hero-button secondary">
                                    Xem menu
                                </a>
                            </div>
                        </div>

                        <div class="hero-image">
                            <img src="~/images/products/tra-sua-matcha.png"
                                 alt="Trà sữa Matcha" />
                        </div>

                    </div>
                </div>

                <!-- HERO 2 -->
                <div class="carousel-item">
                    <div class="hero-content hero-sale">

                        <div class="hero-text">
                            <span class="hero-badge sale">🎁 KHUYẾN MÃI</span>

                            <h1>Mua 2<br />Tặng 1!</h1>

                            <p>
                                Ưu đãi đặc biệt cho các món trà sữa bán chạy.
                                Áp dụng trong tuần này tại MilkTea House.
                            </p>

                            <div class="hero-features">
                                <span><i class="bi bi-check-circle-fill"></i> Ưu đãi hấp dẫn</span>
                                <span><i class="bi bi-check-circle-fill"></i> Áp dụng toàn menu</span>
                                <span><i class="bi bi-check-circle-fill"></i> Số lượng có hạn</span>
                            </div>

                            <div class="hero-actions">
                                <a href="#" class="hero-button primary">
                                    <i class="bi bi-gift"></i>
                                    Nhận ưu đãi
                                </a>

                                <a href="#" class="hero-button secondary">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>

                        <div class="hero-image">
                            <img src="~/images/products/tra-sua-duong-den.png"
                                 alt="Trà sữa Đường đen" />
                        </div>

                    </div>
                </div>

                <!-- HERO 3 -->
                <div class="carousel-item">
                    <div class="hero-content hero-brand">

                        <div class="hero-text">
                            <span class="hero-badge brand">🧋 MILKTEA HOUSE</span>

                            <h1>Nguyên liệu tốt<br />Vị ngon chuẩn!</h1>

                            <p>
                                MilkTea House mang đến những ly trà sữa thơm ngon,
                                an toàn và phù hợp với mọi độ tuổi.
                            </p>

                            <div class="hero-features">
                                <span><i class="bi bi-check-circle-fill"></i> Nguyên liệu chọn lọc</span>
                                <span><i class="bi bi-check-circle-fill"></i> Pha chế chuẩn vị</span>
                                <span><i class="bi bi-check-circle-fill"></i> Phục vụ tận tâm</span>
                            </div>

                            <div class="hero-actions">
                                <a href="#" class="hero-button primary">
                                    Khám phá ngay
                                </a>

                                <a href="#" class="hero-button secondary">
                                    Liên hệ
                                </a>
                            </div>
                        </div>

                        <div class="hero-image hero-image-group">
                            <img src="~/images/products/tra-sua-truyen-thong.png"
                                 alt="Trà sữa Truyền thống" />
                        </div>

                    </div>
                </div>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#milkTeaHero" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#milkTeaHero" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>

    </section>
    <section class="features-section">
        <div class="container">

            <div class="section-title">
                <h2>Vì sao chọn MilkTea House?</h2>
                <p>Chúng tôi luôn mang đến những ly trà sữa thơm ngon, an toàn và chất lượng.</p>
            </div>

            <div class="features-grid">

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-cup-straw"></i>
                    </div>

                    <h3>Hương vị thơm ngon</h3>
                    <p>Trà sữa được pha chế theo công thức riêng, vị ngọt béo hài hòa, dễ uống.</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-patch-check"></i>
                    </div>

                    <h3>Nguyên liệu chất lượng</h3>
                    <p>Sử dụng trà, sữa và topping được chọn lọc kỹ, đảm bảo an toàn cho khách hàng.</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-truck"></i>
                    </div>

                    <h3>Phục vụ nhanh chóng</h3>
                    <p>Đặt hàng dễ dàng, xử lý đơn nhanh, phù hợp với học sinh, sinh viên và nhân viên văn phòng.</p>
                </div>

            </div>
        </div>
    </section>
<section class="featured-products">

    <div class="container">

        <div class="section-heading">
            <h2>Sản phẩm nổi bật</h2>
            <a href="#">Xem tất cả →</a>
        </div>

        <div class="product-list">

            @foreach (var item in Model)
            {
                <div class="product-card">
                    <div class="product-image">

                        @if (item.NhanSanPham == 1)
                        {
                            <span class="product-badge">🔥 HOT</span>
                        }
                        else if (item.NhanSanPham == 2)
                        {
                            <span class="product-badge new">NEW</span>
                        }

                        <img src="@item.HinhAnh"
                             alt="@item.TenSanPham"
                             class="product-photo" />
                    </div>

                    <div class="product-info">
                        <h4>@item.TenSanPham</h4>

                        <div class="product-rating">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <span>(@item.DanhGia)</span>
                        </div>

                        <div class="product-price">
                            @if (item.GiaGoc != null && item.GiaGoc > item.Gia)
                            {
                                <span class="old-price">@item.GiaGoc.Value.ToString("N0")đ</span>
                                <span class="new-price">@item.Gia.ToString("N0")đ</span>
                            }
                            else
                            {
                                <span class="new-price">@item.Gia.ToString("N0")đ</span>
                            }
                        </div>
                    </div>

                    <div class="product-action">
                        <a href="#" class="btn-add-cart">
                            <i class="bi bi-cart-plus"></i>
                            Thêm vào giỏ
                        </a>
                    </div>
                </div>
            }

        </div>

    </div>

</section>
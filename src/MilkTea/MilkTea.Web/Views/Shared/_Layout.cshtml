@using System.Text.Json
@using Microsoft.AspNetCore.Http
@using MilkTea.Web.Models

@{
    string? duLieuGioHang =
        Context.Session.GetString("GioHang");

    var gioHang = string.IsNullOrWhiteSpace(duLieuGioHang)
        ? new System.Collections.Generic.List<GioHangItem>()
        : JsonSerializer.Deserialize<
            System.Collections.Generic.List<GioHangItem>
          >(duLieuGioHang)
          ?? new System.Collections.Generic.List<GioHangItem>();

    int tongSoLuongTrongGio = 0;

    foreach (var item in gioHang)
    {
        tongSoLuongTrongGio += item.SoLuong;
    }
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MilkTea House</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/header.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/home.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/product.css"
          asp-append-version="true" />
</head>

<body>

    <header class="main-header">

        <div class="header-inner">

            <a class="brand-logo"
               asp-controller="Home"
               asp-action="Index">

                <i class="bi bi-house-heart"></i>

                <span>
                    MilkTea House
                </span>

            </a>

            <nav class="main-menu">

                <a class="active"
                   asp-controller="Home"
                   asp-action="Index">
                    Trang chủ
                </a>

                <a asp-controller="SanPham"
                   asp-action="Index">
                    Sản phẩm
                </a>

                <a href="#">
                    Khuyến mãi
                </a>

                <a href="#">
                    Tin tức
                </a>

                <a asp-controller="Home"
                   asp-action="Privacy">
                    Liên hệ
                </a>

            </nav>

            <div class="header-icons">

                <a href="#"
                   title="Tìm kiếm">

                    <i class="bi bi-search"></i>

                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("KhachHang"))
                    {
                        <a asp-controller="DonHangCuaToi"
                           asp-action="Index"
                           title="Đơn hàng của tôi"
                           style="display: inline-flex;
                            align-items: center;
                            gap: 5px;
                            width: auto;
                            color: #6f3814;
                            font-size: 13px;
                            font-weight: 700;
                            text-decoration: none;
                            white-space: nowrap;">

                            <i class="bi bi-bag-check"
                               style="font-size: 18px;">
                            </i>

                            <span>
                                Đơn hàng của tôi
                            </span>

                        </a>
                    }
                    @if (User.IsInRole("QuanTriVien"))
                    {
                        <a asp-controller="QuanLySanPham"
                           asp-action="Index"
                           title="Quản lý sản phẩm">

                            <i class="bi bi-box-seam"></i>

                        </a>
                    }
                    @if (User.IsInRole("NhanVien") ||
                         User.IsInRole("QuanTriVien"))
                    {
                        <a asp-controller="QuanLyDonHang"
                           asp-action="Index"
                           title="Quản lý đơn hàng">

                            <i class="bi bi-clipboard-check"></i>

                        </a>
                    }

                    @if (User.IsInRole("KhachHang"))
                    {
                        <a asp-controller="TaiKhoan"
                           asp-action="ThongTinCaNhan"
                           title="Thông tin cá nhân"
                           style="display: inline-block;
                            max-width: 145px;
                            overflow: hidden;
                            color: #6f3814;
                            font-size: 13px;
                            font-weight: 700;
                            text-decoration: none;
                            text-overflow: ellipsis;
                            white-space: nowrap;">

                            @User.Identity.Name

                        </a>
                    }
                    else
                    {
                        <span title="@User.Identity.Name"
                              style="max-width: 145px;
                            overflow: hidden;
                            color: #6f3814;
                            font-size: 13px;
                            font-weight: 700;
                            text-overflow: ellipsis;
                            white-space: nowrap;">

                            @User.Identity.Name

                        </span>
                    }

                    <form asp-controller="TaiKhoan"
                          asp-action="DangXuat"
                          method="post"
                          style="margin: 0;">

                        @Html.AntiForgeryToken()

                        <button type="submit"
                                title="Đăng xuất"
                                style="padding: 0;
                            border: 0;
                            color: #6f3814;
                            background: transparent;
                            font-size: 20px;
                            cursor: pointer;">

                            <i class="bi bi-box-arrow-right"></i>

                        </button>

                    </form>
                }
                else
                {
                    <div class="account-auth-links">

                        <a asp-controller="TaiKhoan"
                           asp-action="DangKy"
                           class="account-auth-link">

                            Đăng ký

                        </a>

                        <span class="account-auth-divider">
                            /
                        </span>

                        <a asp-controller="TaiKhoan"
                           asp-action="DangNhap"
                           class="account-auth-link">

                            Đăng nhập

                        </a>

                    </div>
                }

                <a asp-controller="GioHang"
                   asp-action="Index"
                   class="cart-icon"
                   title="Giỏ hàng">

                    <i class="bi bi-cart3"></i>

                    @if (tongSoLuongTrongGio > 0)
                    {
                        <span class="cart-count">
                            @tongSoLuongTrongGio
                        </span>
                    }

                </a>

            </div>

        </div>

    </header>

    <main>

        @RenderBody()

    </main>

    <footer class="footer">

        <div class="footer-inner">

            <div class="footer-brand">

                <strong>
                    MilkTea House
                </strong>

                <p>
                    Trà sữa thơm ngon, an toàn và phù hợp với mọi độ tuổi.
                </p>

            </div>

            <div class="footer-copy">
                &copy; 2026 - MilkTea House
            </div>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js">
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">
    </script>

    <script src="~/js/site.js"
            asp-append-version="true">
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)

</body>

</html>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MilkTea House</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product.css" asp-append-version="true" />
</head>

<body>

    <header class="main-header">
        <div class="header-inner">

            <a class="brand-logo" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-heart"></i>
                <span>MilkTea House</span>
            </a>

            <nav class="main-menu">
                <a class="active" asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a href="#products">Sản phẩm</a>
                <a href="#">Khuyến mãi</a>
                <a href="#">Tin tức</a>
                <a asp-controller="Home" asp-action="Privacy">Liên hệ</a>
            </nav>

            <div class="header-icons">
                <a href="#" title="Tìm kiếm"><i class="bi bi-search"></i></a>
                <a href="#" title="Tài khoản"><i class="bi bi-person"></i></a>
                <a href="#" class="cart-icon" title="Giỏ hàng">
                    <i class="bi bi-cart3"></i>
                </a>
            </div>

        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-inner">
            <div class="footer-brand">
                <strong>MilkTea House</strong>
                <p>Trà sữa thơm ngon, an toàn và phù hợp với mọi độ tuổi.</p>
            </div>

            <div class="footer-copy">
                &copy; 2026 - MilkTea House
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
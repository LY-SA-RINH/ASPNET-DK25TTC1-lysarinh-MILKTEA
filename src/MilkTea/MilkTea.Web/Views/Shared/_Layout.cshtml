@using System.Text.Json
@using System.Collections.Generic
@using Microsoft.AspNetCore.Http
@using MilkTea.Web.Models

@{
    string? duLieuGioHang =
        Context.Session.GetString("GioHang");

    List<GioHangItem> gioHang =
        string.IsNullOrWhiteSpace(duLieuGioHang)
            ? new List<GioHangItem>()
            : JsonSerializer.Deserialize<List<GioHangItem>>(
                duLieuGioHang)
              ?? new List<GioHangItem>();

    int tongSoLuongTrongGio = 0;

    foreach (GioHangItem item in gioHang)
    {
        tongSoLuongTrongGio += item.SoLuong;
    }

    string? controllerHienTai =
        ViewContext.RouteData.Values["controller"]?
            .ToString();

    string? actionHienTai =
        ViewContext.RouteData.Values["action"]?
            .ToString();

    bool daDangNhap =
        User.Identity?.IsAuthenticated == true;

    bool laKhachHang =
        daDangNhap &&
        User.IsInRole("KhachHang");

    bool laNhanVien =
        daDangNhap &&
        User.IsInRole("NhanVien");

    bool laQuanTriVien =
        daDangNhap &&
        User.IsInRole("QuanTriVien");

    bool dangOTrangQuanTri =
        controllerHienTai == "QuanLyTongQuan" ||
        controllerHienTai == "QuanLySanPham" ||
        controllerHienTai == "QuanLyDanhMuc" ||
        controllerHienTai == "QuanLyKhachHang" ||
        controllerHienTai == "QuanLyDonHang" ||
        controllerHienTai == "QuanLyLienHe" ||
        controllerHienTai == "BaoCaoDoanhThu";

    string lopTrangChu =
        controllerHienTai == "Home" &&
        actionHienTai == "Index"
            ? "active"
            : string.Empty;

    string lopSanPham =
        controllerHienTai == "SanPham"
            ? "active"
            : string.Empty;

    string lopLienHe =
        controllerHienTai == "LienHe"
            ? "active"
            : string.Empty;

    string lopNutQuanTri =
        dangOTrangQuanTri
            ? "active"
            : string.Empty;

    string lopQuanLyTongQuan =
        controllerHienTai == "QuanLyTongQuan"
            ? "active"
            : string.Empty;

    string lopQuanLySanPham =
        controllerHienTai == "QuanLySanPham"
            ? "active"
            : string.Empty;

    string lopQuanLyDanhMuc =
        controllerHienTai == "QuanLyDanhMuc"
            ? "active"
            : string.Empty;

    string lopQuanLyKhachHang =
        controllerHienTai == "QuanLyKhachHang"
            ? "active"
            : string.Empty;

    string lopQuanLyDonHang =
        controllerHienTai == "QuanLyDonHang"
            ? "active"
            : string.Empty;

    string lopQuanLyLienHe =
        controllerHienTai == "QuanLyLienHe"
            ? "active"
            : string.Empty;

    string lopBaoCaoDoanhThu =
        controllerHienTai == "BaoCaoDoanhThu"
            ? "active"
            : string.Empty;
}

<!DOCTYPE html>

<html lang="vi">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - MilkTea House
    </title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/header.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/home.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/product.css"
          asp-append-version="true" />

</head>

<body>

    <header class="main-header">

        <div class="header-inner">

            <a class="brand-logo"
               asp-controller="Home"
               asp-action="Index">

                <i class="bi bi-house-heart"></i>

                <span>
                    MilkTea House
                </span>

            </a>

            <nav class="main-menu">

                <a class="@lopTrangChu"
                   asp-controller="Home"
                   asp-action="Index">

                    Trang chủ

                </a>

                <a class="@lopSanPham"
                   asp-controller="SanPham"
                   asp-action="Index">

                    Sản phẩm

                </a>

                <a href="#">
                    Khuyến mãi
                </a>

                <a href="#">
                    Tin tức
                </a>

                <a class="@lopLienHe"
                   asp-controller="LienHe"
                   asp-action="Index">

                    Liên hệ

                </a>

            </nav>

            <div class="header-icons">

                @if (!daDangNhap || laKhachHang)
                {
                    <a asp-controller="SanPham"
                       asp-action="Index"
                       asp-fragment="tim-kiem-san-pham"
                       class="header-simple-icon"
                       title="Tìm kiếm sản phẩm"
                       aria-label="Tìm kiếm sản phẩm">

                        <i class="bi bi-search"></i>

                    </a>
                }

                @if (daDangNhap)
                {
                    @if (laKhachHang)
                    {
                        <a asp-controller="DonHangCuaToi"
                           asp-action="Index"
                           class="customer-order-link"
                           title="Đơn hàng của tôi">

                            <i class="bi bi-bag-check"></i>

                            <span>
                                Đơn hàng của tôi
                            </span>

                        </a>
                    }

                    @if (laQuanTriVien)
                    {
                        <div class="dropdown admin-menu-dropdown">

                            <button type="button"
                                    class="admin-menu-button @lopNutQuanTri"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    title="Các chức năng quản trị">

                                <i class="bi bi-grid-1x2-fill"></i>

                                <span>
                                    Quản trị
                                </span>

                                <i class="bi bi-chevron-down admin-menu-chevron">
                                </i>

                            </button>

                            <ul class="dropdown-menu
                                dropdown-menu-end
                                admin-dropdown-menu">

                                <li>

                                    <a asp-controller="QuanLyTongQuan"
                                       asp-action="Index"
                                       class="dropdown-item
                                        admin-dropdown-item
                                        @lopQuanLyTongQuan">

                                        <span class="admin-dropdown-icon">

                                            <i class="bi bi-speedometer2"></i>

                                        </span>

                                        <span>
                                            Tổng quan quản trị
                                        </span>

                                    </a>

                                </li>

                                <li>

                                    <hr class="dropdown-divider
                                    admin-dropdown-divider" />

                                </li>

                                <li>

                                    <a asp-controller="QuanLySanPham"
                                       asp-action="Index"
                                       class="dropdown-item
                                        admin-dropdown-item
                                        @lopQuanLySanPham">

                                        <span class="admin-dropdown-icon">

                                            <i class="bi bi-box-seam"></i>

                                        </span>

                                        <span>
                                            Quản lý sản phẩm
                                        </span>

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="QuanLyDanhMuc"
                                       asp-action="Index"
                                       class="dropdown-item
                                        admin-dropdown-item
                                        @lopQuanLyDanhMuc">

                                        <span class="admin-dropdown-icon">

                                            <i class="bi bi-tags"></i>

                                        </span>

                                        <span>
                                            Quản lý danh mục
                                        </span>

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="QuanLyKhachHang"
                                       asp-action="Index"
                                       class="dropdown-item
                                        admin-dropdown-item
                                        @lopQuanLyKhachHang">

                                        <span class="admin-dropdown-icon">

                                            <i class="bi bi-people"></i>

                                        </span>

                                        <span>
                                            Quản lý khách hàng
                                        </span>

                                    </a>

                                </li>

                                <li>

                                    <hr class="dropdown-divider
                                    admin-dropdown-divider" />

                                </li>

                                <li>

                                    <a asp-controller="QuanLyDonHang"
                                       asp-action="Index"
                                       class="dropdown-item
                                        admin-dropdown-item
                                        @lopQuanLyDonHang">

                                        <span class="admin-dropdown-icon">

                                            <i class="bi bi-clipboard-check"></i>

                                        </span>

                                        <span>
                                            Quản lý đơn hàng
                                        </span>

                                    </a>

                                </li>

                                <li>

                                    <a asp-controller="QuanLyLienHe"
                                       asp-action="Index"
                                       class="dropdown-item
                                        admin-dropdown-item
                                        @lopQuanLyLienHe">

                                        <span class="admin-dropdown-icon">

                                            <i class="bi bi-chat-left-text"></i>

                                        </span>

                                        <span>
                                            Quản lý liên hệ
                                        </span>

                                    </a>

                                </li>

                                <li>

                                    <hr class="dropdown-divider
                                    admin-dropdown-divider" />

                                </li>

                                <li>

                                    <a asp-controller="BaoCaoDoanhThu"
                                       asp-action="Index"
                                       class="dropdown-item
                                        admin-dropdown-item
                                        @lopBaoCaoDoanhThu">

                                        <span class="admin-dropdown-icon">

                                            <i class="bi bi-bar-chart-line"></i>

                                        </span>

                                        <span>
                                            Báo cáo doanh thu
                                        </span>

                                    </a>

                                </li>

                            </ul>

                        </div>
                    }
                    else if (laNhanVien)
                    {
                        <a asp-controller="QuanLyDonHang"
                           asp-action="Index"
                           class="staff-order-link
                            @lopQuanLyDonHang"
                           title="Quản lý đơn hàng">

                            <i class="bi bi-clipboard-check"></i>

                            <span>
                                Đơn hàng
                            </span>

                        </a>
                    }

                    @if (laKhachHang)
                    {
                        <a asp-controller="TaiKhoan"
                           asp-action="ThongTinCaNhan"
                           class="header-user-chip"
                           title="@User.Identity?.Name">

                            <i class="bi bi-person-circle"></i>

                            <span class="header-user-name">
                                @User.Identity?.Name
                            </span>

                        </a>
                    }
                    else
                    {
                        <div class="header-user-chip"
                             title="@User.Identity?.Name">

                            <i class="bi bi-person-circle"></i>

                            <span class="header-user-name">
                                @User.Identity?.Name
                            </span>

                        </div>
                    }

                    <form asp-controller="TaiKhoan"
                          asp-action="DangXuat"
                          method="post"
                          class="header-logout-form">

                        @Html.AntiForgeryToken()

                        <button type="submit"
                                class="header-logout-button"
                                title="Đăng xuất">

                            <i class="bi bi-box-arrow-right"></i>

                        </button>

                    </form>
                }
                else
                {
                    <div class="account-auth-links">

                        <a asp-controller="TaiKhoan"
                           asp-action="DangKy"
                           class="account-auth-link">

                            Đăng ký

                        </a>

                        <span class="account-auth-divider">
                            /
                        </span>

                        <a asp-controller="TaiKhoan"
                           asp-action="DangNhap"
                           class="account-auth-link">

                            Đăng nhập

                        </a>

                    </div>
                }

                @if (!daDangNhap || laKhachHang)
                {
                    <a asp-controller="GioHang"
                       asp-action="Index"
                       class="cart-icon"
                       title="Giỏ hàng">

                        <i class="bi bi-cart3"></i>

                        @if (tongSoLuongTrongGio > 0)
                        {
                            <span class="cart-count">
                                @tongSoLuongTrongGio
                            </span>
                        }

                    </a>
                }

            </div>

        </div>

    </header>

    <main>

        @RenderBody()

    </main>

    <footer class="footer">

        <div class="footer-inner">

            <div class="footer-brand">

                <strong>
                    MilkTea House
                </strong>

                <p>
                    Trà sữa thơm ngon, an toàn và phù hợp với mọi độ tuổi.
                </p>

            </div>

            <div class="footer-copy">
                &copy; 2026 - MilkTea House
            </div>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js">
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">
    </script>

    <script src="~/js/site.js"
            asp-append-version="true">
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)

</body>

</html>
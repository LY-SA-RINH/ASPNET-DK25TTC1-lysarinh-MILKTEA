@using MilkTea.Web.Models
@model MilkTea.Web.Models.ThemSanPhamViewModel

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<style>
    .add-product-page {
        min-height: 100vh;
        padding: 125px 20px 70px;
        background: #fffdfb;
    }

    .add-product-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .add-product-heading {
        margin-bottom: 8px;
        color: #4a1f08;
        font-size: 36px;
        font-weight: 800;
    }

    .add-product-description {
        margin-bottom: 28px;
        color: #75655c;
    }

    .add-product-card {
        padding: 30px;
        background: #ffffff;
        border: 1px solid #ecd7c4;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(91, 47, 15, 0.08);
    }

    .add-product-validation {
        margin-bottom: 20px;
        color: #b42020;
        font-weight: 700;
    }

    .add-product-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
    }

    .add-product-field {
        min-width: 0;
    }

        .add-product-field.full {
            grid-column: 1 / -1;
        }

        .add-product-field label {
            display: block;
            margin-bottom: 7px;
            color: #57331e;
            font-weight: 800;
        }

        .add-product-field input,
        .add-product-field select,
        .add-product-field textarea {
            width: 100%;
            min-height: 48px;
            padding: 10px 13px;
            border: 1px solid #d9bfa7;
            border-radius: 11px;
            box-sizing: border-box;
            color: #3f2a1e;
            background: #ffffff;
            font-family: inherit;
            outline: none;
        }

        .add-product-field textarea {
            min-height: 120px;
            resize: vertical;
        }

            .add-product-field input:focus,
            .add-product-field select:focus,
            .add-product-field textarea:focus {
                border-color: #9b4a00;
                box-shadow: 0 0 0 3px rgba(155, 74, 0, 0.12);
            }

    .add-product-error {
        display: block;
        margin-top: 5px;
        color: #be2020;
        font-size: 13px;
        font-weight: 700;
    }

    .add-product-help {
        display: block;
        margin-top: 6px;
        color: #806f65;
        font-size: 13px;
    }

    .add-product-status {
        min-height: 48px;
        padding: 11px 14px;
        border: 1px solid #d9bfa7;
        border-radius: 11px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-sizing: border-box;
        background: #fffaf5;
    }

        .add-product-status input {
            width: 18px;
            height: 18px;
            min-height: auto;
            margin: 0;
        }

        .add-product-status label {
            margin: 0;
            cursor: pointer;
        }

    .add-product-image-area {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 220px;
        gap: 20px;
        align-items: start;
    }

    .add-product-preview-box {
        min-height: 220px;
        padding: 12px;
        border: 1px dashed #d7b89c;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff8f0;
        overflow: hidden;
    }

    .add-product-preview {
        width: 100%;
        height: 200px;
        display: none;
        object-fit: contain;
    }

    .add-product-preview-placeholder {
        color: #91786a;
        font-size: 14px;
        text-align: center;
        line-height: 1.6;
    }

    .add-product-actions {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

    .add-product-submit,
    .add-product-back {
        min-height: 50px;
        padding: 0 22px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .add-product-submit {
        flex: 1;
        border: 1px solid #9b4a00;
        color: #ffffff;
        background: #9b4a00;
        cursor: pointer;
    }

        .add-product-submit:hover {
            background: #743500;
            border-color: #743500;
        }

    .add-product-back {
        border: 1px solid #d0aa87;
        color: #754018;
        background: #ffffff;
    }

        .add-product-back:hover {
            color: #ffffff;
            background: #9b4a00;
            border-color: #9b4a00;
        }

    @@media (max-width: 750px) {
        .add-product-grid,
        .add-product-image-area {
            grid-template-columns: 1fr;
        }

        .add-product-field.full {
            grid-column: auto;
        }

        .add-product-preview-box {
            max-width: 280px;
        }
    }

    @@media (max-width: 520px) {
        .add-product-page {
            padding: 110px 12px 45px;
        }

        .add-product-card {
            padding: 20px;
        }

        .add-product-heading {
            font-size: 30px;
        }

        .add-product-actions {
            flex-direction: column;
        }
    }
</style>

<section class="add-product-page">

    <div class="add-product-container">

        <h1 class="add-product-heading">
            Thêm sản phẩm mới
        </h1>

        <p class="add-product-description">
            Nhập thông tin sản phẩm sẽ bán tại MilkTea House.
        </p>

        <div class="add-product-card">

            <form asp-controller="QuanLySanPham"
                  asp-action="Them"
                  method="post"
                  enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly"
                     class="add-product-validation">
                </div>

                <div class="add-product-grid">

                    <div class="add-product-field">

                        <label asp-for="DanhMucID">
                            Danh mục
                        </label>

                        <select asp-for="DanhMucID">

                            <option value="">
                                -- Chọn danh mục --
                            </option>

                            @foreach (DanhMuc danhMuc
                                      in Model.DanhMucs)
                            {
                                <option value="@danhMuc.DanhMucID">
                                    @danhMuc.TenDanhMuc
                                </option>
                            }

                        </select>

                        <span asp-validation-for="DanhMucID"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field">

                        <label asp-for="TenSanPham">
                            Tên sản phẩm
                        </label>

                        <input asp-for="TenSanPham"
                               placeholder="Ví dụ: Trà sữa khoai môn" />

                        <span asp-validation-for="TenSanPham"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field">

                        <label asp-for="Gia">
                            Giá bán
                        </label>

                        <input asp-for="Gia"
                               type="number"
                               min="1000"
                               step="1000"
                               placeholder="Ví dụ: 29000" />

                        <span asp-validation-for="Gia"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field">

                        <label asp-for="GiaGoc">
                            Giá gốc
                        </label>

                        <input asp-for="GiaGoc"
                               type="number"
                               min="0"
                               step="1000"
                               placeholder="Để trống nếu không giảm giá" />

                        <span asp-validation-for="GiaGoc"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field">

                        <label asp-for="SoLuongTon">
                            Số lượng tồn
                        </label>

                        <input asp-for="SoLuongTon"
                               type="number"
                               min="0" />

                        <span asp-validation-for="SoLuongTon"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field">

                        <label asp-for="ThuTuHienThi">
                            Thứ tự hiển thị
                        </label>

                        <input asp-for="ThuTuHienThi"
                               type="number"
                               min="0" />

                        <span asp-validation-for="ThuTuHienThi"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field">

                        <label asp-for="NhanSanPham">
                            Nhãn sản phẩm
                        </label>

                        <select asp-for="NhanSanPham">

                            <option value="0">
                                Không có nhãn
                            </option>

                            <option value="1">
                                HOT
                            </option>

                            <option value="2">
                                NEW
                            </option>

                        </select>

                        <span asp-validation-for="NhanSanPham"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field">

                        <label>
                            Trạng thái kinh doanh
                        </label>

                        <div class="add-product-status">

                            <input asp-for="TrangThai"
                                   type="checkbox" />

                            <label asp-for="TrangThai">
                                Mở bán sản phẩm ngay sau khi thêm
                            </label>

                        </div>

                    </div>

                    <div class="add-product-field full">

                        <label asp-for="MoTa">
                            Mô tả sản phẩm
                        </label>

                        <textarea asp-for="MoTa"
                                  placeholder="Nhập mô tả, nguyên liệu hoặc hương vị sản phẩm">
                        </textarea>

                        <span asp-validation-for="MoTa"
                              class="add-product-error">
                        </span>

                    </div>

                    <div class="add-product-field full">

                        <label asp-for="HinhAnhTaiLen">
                            Hình ảnh sản phẩm
                        </label>

                        <div class="add-product-image-area">

                            <div>

                                <input asp-for="HinhAnhTaiLen"
                                       type="file"
                                       accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                                       onchange="xemTruocHinhAnh(this)" />

                                <span asp-validation-for="HinhAnhTaiLen"
                                      class="add-product-error">
                                </span>

                                <small class="add-product-help">
                                    Chấp nhận JPG, JPEG, PNG hoặc WEBP.
                                    Dung lượng tối đa 5 MB.
                                </small>

                            </div>

                            <div class="add-product-preview-box">

                                <img id="hinhAnhXemTruoc"
                                     class="add-product-preview"
                                     alt="Hình ảnh xem trước" />

                                <div id="noiDungChuaCoHinh"
                                     class="add-product-preview-placeholder">

                                    <i class="bi bi-image"
                                       style="font-size: 35px;">
                                    </i>

                                    <div>
                                        Chưa chọn hình ảnh
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <div class="add-product-actions">

                    <button type="submit"
                            class="add-product-submit">

                        <i class="bi bi-plus-circle"></i>

                        Thêm sản phẩm

                    </button>

                    <a asp-controller="QuanLySanPham"
                       asp-action="Index"
                       class="add-product-back">

                        <i class="bi bi-arrow-left"></i>

                        Quay lại

                    </a>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        function xemTruocHinhAnh(input) {
            const hinhAnh =
                document.getElementById(
                    "hinhAnhXemTruoc");

            const noiDungChuaCoHinh =
                document.getElementById(
                    "noiDungChuaCoHinh");

            if (input.files &&
                input.files.length > 0) {

                const tep = input.files[0];
                const duongDanTam =
                    URL.createObjectURL(tep);

                hinhAnh.src = duongDanTam;
                hinhAnh.style.display = "block";

                noiDungChuaCoHinh.style.display =
                    "none";

                hinhAnh.onload = function () {
                    URL.revokeObjectURL(
                        duongDanTam);
                };
            }
            else {
                hinhAnh.removeAttribute("src");
                hinhAnh.style.display = "none";

                noiDungChuaCoHinh.style.display =
                    "block";
            }
        }
    </script>
}
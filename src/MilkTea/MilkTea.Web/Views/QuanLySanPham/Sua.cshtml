@using MilkTea.Web.Models
@model MilkTea.Web.Models.SuaSanPhamViewModel

@{
    ViewData["Title"] = "Sửa sản phẩm";

    string duongDanHinhAnh = "/images/products/san-pham-mac-dinh.png";

    if (!string.IsNullOrWhiteSpace(Model.HinhAnhHienTai))
    {
        string hinhAnh = Model.HinhAnhHienTai.Replace("\\", "/");

        if (hinhAnh.StartsWith("/"))
        {
            duongDanHinhAnh = hinhAnh;
        }
        else if (hinhAnh.StartsWith("images/"))
        {
            duongDanHinhAnh = "/" + hinhAnh;
        }
        else
        {
            duongDanHinhAnh =
                "/images/products/" + hinhAnh;
        }
    }
}

<style>
    .edit-product-page {
        min-height: 100vh;
        padding: 125px 20px 70px;
        background: #fffdfb;
    }

    .edit-product-container {
        max-width: 1050px;
        margin: 0 auto;
    }

    .edit-product-heading-area {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 28px;
    }

    .edit-product-heading {
        margin: 0 0 8px;
        color: #4a1f08;
        font-size: 36px;
        font-weight: 800;
    }

    .edit-product-description {
        margin: 0;
        color: #75655c;
    }

    .edit-product-id {
        padding: 10px 14px;
        border: 1px solid #e0c4aa;
        border-radius: 10px;
        color: #704522;
        background: #fff7ed;
        font-weight: 800;
        white-space: nowrap;
    }

    .edit-product-card {
        padding: 30px;
        border: 1px solid #ecd7c4;
        border-radius: 20px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(91, 47, 15, 0.08);
    }

    .edit-product-validation {
        margin-bottom: 20px;
        padding: 12px 15px;
        border-radius: 10px;
        color: #a72020;
        background: #fff1f1;
        font-weight: 700;
    }

        .edit-product-validation:empty {
            display: none;
        }

    .edit-product-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
    }

    .edit-product-field {
        min-width: 0;
    }

        .edit-product-field.full {
            grid-column: 1 / -1;
        }

        .edit-product-field > label {
            display: block;
            margin-bottom: 7px;
            color: #57331e;
            font-weight: 800;
        }

    .edit-product-required {
        color: #be2020;
    }

    .edit-product-field input,
    .edit-product-field select,
    .edit-product-field textarea {
        width: 100%;
        min-height: 48px;
        padding: 10px 13px;
        border: 1px solid #d9bfa7;
        border-radius: 11px;
        box-sizing: border-box;
        color: #3f2a1e;
        background: #ffffff;
        font-family: inherit;
        outline: none;
    }

    .edit-product-field textarea {
        min-height: 125px;
        resize: vertical;
    }

        .edit-product-field input:focus,
        .edit-product-field select:focus,
        .edit-product-field textarea:focus {
            border-color: #9b4a00;
            box-shadow: 0 0 0 3px rgba(155, 74, 0, 0.12);
        }

    .edit-product-error {
        display: block;
        margin-top: 5px;
        color: #be2020;
        font-size: 13px;
        font-weight: 700;
    }

    .edit-product-help {
        display: block;
        margin-top: 6px;
        color: #806f65;
        font-size: 13px;
        line-height: 1.5;
    }

    .edit-product-status {
        min-height: 48px;
        padding: 11px 14px;
        border: 1px solid #d9bfa7;
        border-radius: 11px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-sizing: border-box;
        background: #fffaf5;
    }

        .edit-product-status input {
            width: 18px;
            height: 18px;
            min-height: auto;
            margin: 0;
            cursor: pointer;
        }

        .edit-product-status label {
            margin: 0;
            color: #57331e;
            font-weight: 800;
            cursor: pointer;
        }

    .edit-product-image-area {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 260px;
        gap: 22px;
        align-items: start;
    }

    .edit-product-image-input {
        padding: 18px;
        border: 1px solid #ead3bd;
        border-radius: 14px;
        background: #fffaf5;
    }

    .edit-product-preview-wrapper {
        overflow: hidden;
        border: 1px dashed #d7b89c;
        border-radius: 15px;
        background: #fff8f0;
    }

    .edit-product-preview-title {
        padding: 10px 12px;
        border-bottom: 1px solid #ead3bd;
        color: #69401f;
        background: #fff3e7;
        font-size: 14px;
        font-weight: 800;
        text-align: center;
    }

    .edit-product-preview-box {
        min-height: 260px;
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .edit-product-preview {
        width: 100%;
        height: 230px;
        object-fit: contain;
        display: block;
    }

    .edit-product-image-note {
        margin-top: 12px;
        padding: 10px 12px;
        border-radius: 9px;
        color: #755233;
        background: #fff1df;
        font-size: 13px;
        line-height: 1.5;
    }

    .edit-product-actions {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

    .edit-product-submit,
    .edit-product-back {
        min-height: 50px;
        padding: 0 22px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .edit-product-submit {
        flex: 1;
        border: 1px solid #9b4a00;
        color: #ffffff;
        background: #9b4a00;
        cursor: pointer;
    }

        .edit-product-submit:hover {
            background: #743500;
            border-color: #743500;
        }

    .edit-product-back {
        border: 1px solid #d0aa87;
        color: #754018;
        background: #ffffff;
    }

        .edit-product-back:hover {
            color: #ffffff;
            background: #8a4a18;
            border-color: #8a4a18;
        }

    @@media (max-width: 780px) {
        .edit-product-grid,
        .edit-product-image-area {
            grid-template-columns: 1fr;
        }

        .edit-product-field.full {
            grid-column: auto;
        }

        .edit-product-preview-wrapper {
            max-width: 320px;
        }
    }

    @@media (max-width: 560px) {
        .edit-product-page {
            padding: 110px 12px 45px;
        }

        .edit-product-card {
            padding: 20px;
        }

        .edit-product-heading-area {
            flex-direction: column;
        }

        .edit-product-heading {
            font-size: 30px;
        }

        .edit-product-actions {
            flex-direction: column;
        }

        .edit-product-submit,
        .edit-product-back {
            width: 100%;
        }
    }
</style>

<section class="edit-product-page">

    <div class="edit-product-container">

        <div class="edit-product-heading-area">

            <div>
                <h1 class="edit-product-heading">
                    Sửa sản phẩm
                </h1>

                <p class="edit-product-description">
                    Cập nhật thông tin sản phẩm đang có tại MilkTea House.
                </p>
            </div>

            <div class="edit-product-id">
                Mã sản phẩm: #@Model.SanPhamID
            </div>

        </div>

        <div class="edit-product-card">

            <form asp-controller="QuanLySanPham"
                  asp-action="Sua"
                  method="post"
                  enctype="multipart/form-data">

                <input asp-for="SanPhamID"
                       type="hidden" />

                <input asp-for="HinhAnhHienTai"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="edit-product-validation">
                </div>

                <div class="edit-product-grid">

                    <div class="edit-product-field">

                        <label asp-for="DanhMucID">
                            Danh mục
                            <span class="edit-product-required">*</span>
                        </label>

                        <select asp-for="DanhMucID">

                            <option value="">
                                -- Chọn danh mục --
                            </option>

                            @foreach (DanhMuc danhMuc in Model.DanhMucs)
                            {
                                <option value="@danhMuc.DanhMucID">
                                    @danhMuc.TenDanhMuc
                                </option>
                            }

                        </select>

                        <span asp-validation-for="DanhMucID"
                              class="edit-product-error">
                        </span>

                    </div>

                    <div class="edit-product-field">

                        <label asp-for="TenSanPham">
                            Tên sản phẩm
                            <span class="edit-product-required">*</span>
                        </label>

                        <input asp-for="TenSanPham"
                               placeholder="Nhập tên sản phẩm" />

                        <span asp-validation-for="TenSanPham"
                              class="edit-product-error">
                        </span>

                    </div>

                    <div class="edit-product-field">

                        <label asp-for="Gia">
                            Giá bán
                            <span class="edit-product-required">*</span>
                        </label>

                        <input asp-for="Gia"
                               asp-format="{0:0}"
                               type="number"
                               min="1000"
                               step="1"
                               placeholder="Ví dụ: 32000" />

                        <span asp-validation-for="Gia"
                              class="edit-product-error">
                        </span>

                    </div>

                    <div class="edit-product-field">

                        <label asp-for="GiaGoc">
                            Giá gốc
                        </label>

                        <input asp-for="GiaGoc"
                               asp-format="{0:0}"
                               type="number"
                               min="0"
                               step="1"
                               placeholder="Để trống nếu không giảm giá" />

                        <span asp-validation-for="GiaGoc"
                              class="edit-product-error">
                        </span>

                        <small class="edit-product-help">
                            Giá gốc phải lớn hơn giá bán hoặc để trống.
                        </small>

                    </div>

                    <div class="edit-product-field">

                        <label asp-for="SoLuongTon">
                            Số lượng tồn
                        </label>

                        <input asp-for="SoLuongTon"
                               type="number"
                               min="0" />

                        <span asp-validation-for="SoLuongTon"
                              class="edit-product-error">
                        </span>

                    </div>

                    <div class="edit-product-field">

                        <label asp-for="ThuTuHienThi">
                            Thứ tự hiển thị
                        </label>

                        <input asp-for="ThuTuHienThi"
                               type="number"
                               min="0" />

                        <span asp-validation-for="ThuTuHienThi"
                              class="edit-product-error">
                        </span>

                    </div>

                    <div class="edit-product-field">

                        <label asp-for="NhanSanPham">
                            Nhãn sản phẩm
                        </label>

                        <select asp-for="NhanSanPham">

                            <option value="0">
                                Không có nhãn
                            </option>

                            <option value="1">
                                HOT
                            </option>

                            <option value="2">
                                NEW
                            </option>

                        </select>

                        <span asp-validation-for="NhanSanPham"
                              class="edit-product-error">
                        </span>

                    </div>

                    <div class="edit-product-field">

                        <label>
                            Trạng thái kinh doanh
                        </label>

                        <div class="edit-product-status">

                            <input asp-for="TrangThai"
                                   type="checkbox" />

                            <label asp-for="TrangThai">
                                Sản phẩm đang được mở bán
                            </label>

                        </div>

                        <small class="edit-product-help">
                            Bỏ chọn để chuyển sản phẩm sang trạng thái
                            tạm ngưng bán.
                        </small>

                    </div>

                    <div class="edit-product-field full">

                        <label asp-for="MoTa">
                            Mô tả sản phẩm
                        </label>

                        <textarea asp-for="MoTa"
                                  placeholder="Nhập mô tả, nguyên liệu hoặc hương vị sản phẩm"></textarea>

                        <span asp-validation-for="MoTa"
                              class="edit-product-error">
                        </span>

                    </div>

                    <div class="edit-product-field full">

                        <label asp-for="HinhAnhTaiLen">
                            Hình ảnh sản phẩm
                        </label>

                        <div class="edit-product-image-area">

                            <div class="edit-product-image-input">

                                <input asp-for="HinhAnhTaiLen"
                                       type="file"
                                       accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                                       onchange="xemTruocHinhAnh(this)" />

                                <span asp-validation-for="HinhAnhTaiLen"
                                      class="edit-product-error">
                                </span>

                                <small class="edit-product-help">
                                    Chấp nhận JPG, JPEG, PNG hoặc WEBP.
                                    Dung lượng tối đa 5 MB.
                                </small>

                                <div class="edit-product-image-note">

                                    <strong>Lưu ý:</strong>

                                    Không chọn hình mới thì hệ thống sẽ giữ
                                    nguyên hình ảnh hiện tại của sản phẩm.

                                </div>

                            </div>

                            <div class="edit-product-preview-wrapper">

                                <div class="edit-product-preview-title"
                                     id="tieuDeXemTruoc">
                                    Hình ảnh hiện tại
                                </div>

                                <div class="edit-product-preview-box">

                                    <img id="hinhAnhXemTruoc"
                                         class="edit-product-preview"
                                         src="@duongDanHinhAnh"
                                         data-hinh-cu="@duongDanHinhAnh"
                                         alt="@Model.TenSanPham"
                                         onerror="this.onerror=null; this.src='/images/products/san-pham-mac-dinh.png';" />

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <div class="edit-product-actions">

                    <button type="submit"
                            class="edit-product-submit">

                        <i class="bi bi-check-circle"></i>

                        Lưu thay đổi

                    </button>

                    <a asp-controller="QuanLySanPham"
                       asp-action="Index"
                       class="edit-product-back">

                        <i class="bi bi-arrow-left"></i>

                        Quay lại

                    </a>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        function xemTruocHinhAnh(input) {
            const hinhAnh =
                document.getElementById(
                    "hinhAnhXemTruoc");

            const tieuDe =
                document.getElementById(
                    "tieuDeXemTruoc");

            if (input.files &&
                input.files.length > 0) {

                const tep = input.files[0];

                if (!tep.type.startsWith("image/")) {
                    input.value = "";

                    hinhAnh.src =
                        hinhAnh.dataset.hinhCu;

                    tieuDe.textContent =
                        "Hình ảnh hiện tại";

                    return;
                }

                const duongDanTam =
                    URL.createObjectURL(tep);

                hinhAnh.src = duongDanTam;

                tieuDe.textContent =
                    "Hình ảnh mới";

                hinhAnh.onload = function () {
                    URL.revokeObjectURL(
                        duongDanTam);
                };
            }
            else {
                hinhAnh.src =
                    hinhAnh.dataset.hinhCu;

                tieuDe.textContent =
                    "Hình ảnh hiện tại";
            }
        }
    </script>
}
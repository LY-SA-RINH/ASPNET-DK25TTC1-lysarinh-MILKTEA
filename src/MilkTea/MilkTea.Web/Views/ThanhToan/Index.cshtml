@model MilkTea.Web.Models.ThanhToanViewModel

@{
    ViewData["Title"] = "Thanh toán";
}

<style>
    .checkout-page {
        min-height: 100vh;
        padding: 125px 20px 70px;
        background: #fffdfb;
    }

    .checkout-container {
        max-width: 1150px;
        margin: 0 auto;
    }

    .checkout-heading {
        margin-bottom: 10px;
        color: #4a1f08;
        font-size: 38px;
        font-weight: 800;
        text-align: center;
    }

    .checkout-description {
        margin-bottom: 34px;
        color: #75655c;
        text-align: center;
    }

    .checkout-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 28px;
        align-items: start;
    }

    .checkout-form-box,
    .checkout-summary {
        padding: 26px;
        background: #ffffff;
        border: 1px solid #ecd7c4;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(91, 47, 15, 0.07);
    }

        .checkout-form-box h2,
        .checkout-summary h2 {
            margin: 0 0 22px;
            color: #4a1f08;
            font-size: 24px;
            font-weight: 800;
        }

    .checkout-validation {
        margin-bottom: 18px;
        color: #b42020;
        font-weight: 700;
    }

    .checkout-field {
        margin-bottom: 18px;
    }

        .checkout-field label {
            display: block;
            margin-bottom: 7px;
            color: #57331e;
            font-weight: 800;
        }

        .checkout-field input,
        .checkout-field textarea,
        .checkout-field select {
            width: 100%;
            min-height: 46px;
            padding: 10px 13px;
            border: 1px solid #d9bfa7;
            border-radius: 11px;
            box-sizing: border-box;
            color: #3f2a1e;
            background: #ffffff;
            font-family: inherit;
            outline: none;
        }

        .checkout-field textarea {
            min-height: 105px;
            resize: vertical;
        }

            .checkout-field input:focus,
            .checkout-field textarea:focus,
            .checkout-field select:focus {
                border-color: #9b4a00;
                box-shadow: 0 0 0 3px rgba(155, 74, 0, 0.12);
            }

    .checkout-error {
        display: block;
        margin-top: 5px;
        color: #be2020;
        font-size: 13px;
        font-weight: 700;
    }

    .checkout-submit {
        width: 100%;
        min-height: 50px;
        border: 1px solid #9b4a00;
        border-radius: 12px;
        color: #ffffff;
        background: #9b4a00;
        font-size: 16px;
        font-weight: 800;
        cursor: pointer;
        transition: 0.2s ease;
    }

        .checkout-submit:hover {
            background: #743500;
            border-color: #743500;
        }

    .checkout-summary {
        position: sticky;
        top: 105px;
        background: #fff8ef;
    }

    .checkout-product {
        display: grid;
        grid-template-columns: 58px minmax(0, 1fr) auto;
        gap: 11px;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #ead6c3;
    }

        .checkout-product img {
            width: 58px;
            height: 58px;
            padding: 4px;
            border-radius: 10px;
            object-fit: contain;
            background: #ffffff;
        }

    .checkout-product-name {
        color: #4a1f08;
        font-weight: 800;
    }

    .checkout-product-quantity {
        color: #837166;
        font-size: 13px;
    }

    .checkout-product-price {
        color: #a14000;
        font-weight: 800;
        white-space: nowrap;
    }

    .checkout-total-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-top: 18px;
        color: #5f483a;
    }

        .checkout-total-row.final {
            padding-top: 17px;
            border-top: 1px solid #d9bea3;
            color: #4a1f08;
            font-size: 19px;
            font-weight: 800;
        }

            .checkout-total-row.final strong {
                color: #c8001b;
                font-size: 24px;
            }

    .checkout-back {
        margin-top: 14px;
        display: block;
        color: #7c3c0d;
        text-align: center;
        text-decoration: none;
        font-weight: 800;
    }

    @@media (max-width: 900px) {
        .checkout-layout {
            grid-template-columns: 1fr;
        }

        .checkout-summary {
            position: static;
        }
    }

    @@media (max-width: 520px) {
        .checkout-page {
            padding: 110px 12px 45px;
        }

        .checkout-heading {
            font-size: 30px;
        }

        .checkout-form-box,
        .checkout-summary {
            padding: 18px;
        }
    }
</style>

<section class="checkout-page">

    <div class="checkout-container">

        <h1 class="checkout-heading">
            Thông tin đặt hàng
        </h1>

        <p class="checkout-description">
            Vui lòng kiểm tra thông tin trước khi xác nhận.
        </p>

        <div class="checkout-layout">

            <div class="checkout-form-box">

                <h2>Thông tin người nhận</h2>

                <form asp-controller="ThanhToan"
                      asp-action="DatHang"
                      method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="checkout-validation">
                    </div>

                    <div class="checkout-field">
                        <label asp-for="HoTen">
                            Họ tên người nhận
                        </label>

                        <input asp-for="HoTen"
                               placeholder="Nhập họ tên người nhận" />

                        <span asp-validation-for="HoTen"
                              class="checkout-error">
                        </span>
                    </div>

                    <div class="checkout-field">
                        <label asp-for="SoDienThoai">
                            Số điện thoại
                        </label>

                        <input asp-for="SoDienThoai"
                               placeholder="Ví dụ: 0912345678" />

                        <span asp-validation-for="SoDienThoai"
                              class="checkout-error">
                        </span>
                    </div>

                    <div class="checkout-field">
                        <label asp-for="DiaChi">
                            Địa chỉ giao hàng
                        </label>

                        <input asp-for="DiaChi"
                               placeholder="Nhập địa chỉ nhận hàng" />

                        <span asp-validation-for="DiaChi"
                              class="checkout-error">
                        </span>
                    </div>

                    <div class="checkout-field">
                        <label asp-for="GhiChu">
                            Ghi chú
                        </label>

                        <textarea asp-for="GhiChu"
                                  placeholder="Ghi chú thêm nếu có">
                        </textarea>

                        <span asp-validation-for="GhiChu"
                              class="checkout-error">
                        </span>
                    </div>

                    <div class="checkout-field">
                        <label asp-for="PhuongThucThanhToan">
                            Phương thức thanh toán
                        </label>

                        <select asp-for="PhuongThucThanhToan">
                            <option value="Thanh toán khi nhận hàng">
                                Thanh toán khi nhận hàng
                            </option>
                        </select>
                    </div>

                    <button type="submit"
                            class="checkout-submit">

                        <i class="bi bi-check-circle"></i>
                        Xác nhận đặt hàng
                    </button>

                </form>

            </div>

            <aside class="checkout-summary">

                <h2>Đơn hàng của bạn</h2>

                @foreach (var item in Model.GioHang)
                {
                    <div class="checkout-product">

                        <img src="/images/products/@item.HinhAnh"
                             alt="@item.TenSanPham"
                             onerror="this.onerror=null; this.src='/images/products/san-pham-mac-dinh.png';" />

                        <div>
                            <div class="checkout-product-name">
                                @item.TenSanPham
                            </div>

                            <div class="checkout-product-quantity">
                                Số lượng: @item.SoLuong
                            </div>
                        </div>

                        <div class="checkout-product-price">
                            @item.ThanhTien.ToString("N0")đ
                        </div>

                    </div>
                }

                <div class="checkout-total-row">
                    <span>Tổng số lượng</span>
                    <strong>@Model.TongSoLuong sản phẩm</strong>
                </div>

                <div class="checkout-total-row final">
                    <span>Tổng tiền</span>
                    <strong>@Model.TongTien.ToString("N0")đ</strong>
                </div>

                <a asp-controller="GioHang"
                   asp-action="Index"
                   class="checkout-back">

                    <i class="bi bi-arrow-left"></i>
                    Quay lại giỏ hàng
                </a>

            </aside>

        </div>

    </div>

</section>
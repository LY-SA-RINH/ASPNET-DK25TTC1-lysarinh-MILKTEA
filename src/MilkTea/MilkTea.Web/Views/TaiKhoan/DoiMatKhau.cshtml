@model MilkTea.Web.Models.DoiMatKhauViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<style>
    .change-password-page {
        min-height: 100vh;
        padding: 130px 20px 70px;
        background: #fffdfb;
    }

    .change-password-container {
        max-width: 620px;
        margin: 0 auto;
    }

    .change-password-heading {
        margin-bottom: 8px;
        color: #4a1f08;
        font-size: 38px;
        font-weight: 800;
        text-align: center;
    }

    .change-password-description {
        margin-bottom: 30px;
        color: #75655c;
        text-align: center;
    }

    .change-password-card {
        padding: 30px;
        background: #ffffff;
        border: 1px solid #ecd7c4;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(91, 47, 15, 0.08);
    }

    .change-password-note {
        padding: 14px 16px;
        margin-bottom: 22px;
        color: #654028;
        background: #fff5e9;
        border: 1px solid #ead2b8;
        border-radius: 11px;
        font-size: 14px;
        line-height: 1.6;
    }

    .change-password-validation {
        margin-bottom: 18px;
        color: #b42020;
        font-weight: 700;
    }

    .change-password-field {
        margin-bottom: 20px;
    }

        .change-password-field label {
            display: block;
            margin-bottom: 7px;
            color: #57331e;
            font-weight: 800;
        }

    .password-input-wrapper {
        position: relative;
    }

        .password-input-wrapper input {
            width: 100%;
            min-height: 48px;
            padding: 10px 48px 10px 13px;
            border: 1px solid #d9bfa7;
            border-radius: 11px;
            box-sizing: border-box;
            color: #3f2a1e;
            background: #ffffff;
            outline: none;
        }

            .password-input-wrapper input:focus {
                border-color: #9b4a00;
                box-shadow: 0 0 0 3px rgba(155, 74, 0, 0.12);
            }

    .password-toggle {
        position: absolute;
        top: 50%;
        right: 13px;
        padding: 4px;
        border: 0;
        color: #7c4a29;
        background: transparent;
        font-size: 19px;
        line-height: 1;
        cursor: pointer;
        transform: translateY(-50%);
    }

    .change-password-error {
        display: block;
        margin-top: 5px;
        color: #be2020;
        font-size: 13px;
        font-weight: 700;
    }

    .change-password-actions {
        display: flex;
        gap: 12px;
        margin-top: 27px;
    }

    .change-password-submit {
        flex: 1;
        min-height: 49px;
        border: 1px solid #9b4a00;
        border-radius: 11px;
        color: #ffffff;
        background: #9b4a00;
        font-weight: 800;
        cursor: pointer;
        transition: 0.2s ease;
    }

        .change-password-submit:hover {
            background: #743500;
            border-color: #743500;
        }

    .change-password-back {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 49px;
        padding: 0 18px;
        border: 1px solid #9b4a00;
        border-radius: 11px;
        color: #7c3c0d;
        background: #ffffff;
        font-weight: 800;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .change-password-back:hover {
            color: #ffffff;
            background: #9b4a00;
        }

    @@media (max-width: 600px) {
        .change-password-page {
            padding: 115px 12px 45px;
        }

        .change-password-card {
            padding: 20px;
        }

        .change-password-heading {
            font-size: 30px;
        }

        .change-password-actions {
            flex-direction: column;
        }
    }
</style>

<section class="change-password-page">

    <div class="change-password-container">

        <h1 class="change-password-heading">
            Đổi mật khẩu
        </h1>

        <p class="change-password-description">
            Cập nhật mật khẩu để bảo vệ tài khoản của bạn.
        </p>

        @if (TempData["ThanhCong"] != null)
        {
            <div class="alert alert-success
                alert-dismissible fade show"
                 role="alert">

                <i class="bi bi-check-circle-fill me-2"></i>

                @TempData["ThanhCong"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Đóng">
                </button>

            </div>
        }

        <div class="change-password-card">

            <div class="change-password-note">

                <i class="bi bi-shield-lock me-1"></i>

                Mật khẩu mới phải có ít nhất 6 ký tự,
                gồm chữ hoa, chữ thường, chữ số và ký tự đặc biệt.

            </div>

            <form asp-controller="TaiKhoan"
                  asp-action="DoiMatKhau"
                  method="post">

                <div asp-validation-summary="ModelOnly"
                     class="change-password-validation">
                </div>

                <div class="change-password-field">

                    <label asp-for="MatKhauHienTai">
                        Mật khẩu hiện tại
                    </label>

                    <div class="password-input-wrapper">

                        <input asp-for="MatKhauHienTai"
                               id="MatKhauHienTai"
                               type="password"
                               autocomplete="current-password"
                               placeholder="Nhập mật khẩu hiện tại" />

                        <button type="button"
                                class="password-toggle"
                                title="Hiện hoặc ẩn mật khẩu"
                                onclick="thayDoiHienThiMatKhau(
                            'MatKhauHienTai',
                            this)">

                            <i class="bi bi-eye"></i>

                        </button>

                    </div>

                    <span asp-validation-for="MatKhauHienTai"
                          class="change-password-error">
                    </span>

                </div>

                <div class="change-password-field">

                    <label asp-for="MatKhauMoi">
                        Mật khẩu mới
                    </label>

                    <div class="password-input-wrapper">

                        <input asp-for="MatKhauMoi"
                               id="MatKhauMoi"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Nhập mật khẩu mới" />

                        <button type="button"
                                class="password-toggle"
                                title="Hiện hoặc ẩn mật khẩu"
                                onclick="thayDoiHienThiMatKhau(
                            'MatKhauMoi',
                            this)">

                            <i class="bi bi-eye"></i>

                        </button>

                    </div>

                    <span asp-validation-for="MatKhauMoi"
                          class="change-password-error">
                    </span>

                </div>

                <div class="change-password-field">

                    <label asp-for="XacNhanMatKhauMoi">
                        Xác nhận mật khẩu mới
                    </label>

                    <div class="password-input-wrapper">

                        <input asp-for="XacNhanMatKhauMoi"
                               id="XacNhanMatKhauMoi"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Nhập lại mật khẩu mới" />

                        <button type="button"
                                class="password-toggle"
                                title="Hiện hoặc ẩn mật khẩu"
                                onclick="thayDoiHienThiMatKhau(
                            'XacNhanMatKhauMoi',
                            this)">

                            <i class="bi bi-eye"></i>

                        </button>

                    </div>

                    <span asp-validation-for="XacNhanMatKhauMoi"
                          class="change-password-error">
                    </span>

                </div>

                <div class="change-password-actions">

                    <button type="submit"
                            class="change-password-submit">

                        <i class="bi bi-key me-1"></i>

                        Đổi mật khẩu

                    </button>

                    <a asp-controller="TaiKhoan"
                       asp-action="ThongTinCaNhan"
                       class="change-password-back">

                        <i class="bi bi-arrow-left me-1"></i>

                        Quay lại

                    </a>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        function thayDoiHienThiMatKhau(
            idONhap,
            nutBam) {

            const oNhap =
                document.getElementById(idONhap);

            const bieuTuong =
                nutBam.querySelector("i");

            if (oNhap.type === "password") {
                oNhap.type = "text";

                bieuTuong.classList.remove(
                    "bi-eye");

                bieuTuong.classList.add(
                    "bi-eye-slash");
            }
            else {
                oNhap.type = "password";

                bieuTuong.classList.remove(
                    "bi-eye-slash");

                bieuTuong.classList.add(
                    "bi-eye");
            }
        }
    </script>
}
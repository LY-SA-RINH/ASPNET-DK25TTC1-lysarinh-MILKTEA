@model MilkTea.Web.Models.DatLaiMatKhauViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<section class="container"
         style="max-width: 560px;
    padding-top: 145px;
    padding-bottom: 80px;">

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">

                <i class="bi bi-shield-lock"
                   style="font-size: 58px;
                    color: #9b4a00;">
                </i>

                <h1 class="fw-bold mt-3 mb-2"
                    style="color: #4a1f08;">
                    Đặt lại mật khẩu
                </h1>

                <p class="text-secondary mb-0">
                    Nhập mật khẩu mới cho tài khoản của bạn.
                </p>

            </div>

            <form asp-controller="TaiKhoan"
                  asp-action="DatLaiMatKhau"
                  method="post">

                <input asp-for="Email"
                       type="hidden" />

                <input asp-for="MaXacNhan"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label asp-for="MatKhauMoi"
                           class="form-label fw-bold">
                    </label>

                    <div class="input-group">

                        <input asp-for="MatKhauMoi"
                               class="form-control"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Nhập mật khẩu mới" />

                        <button type="button"
                                id="nutHienMatKhauMoi"
                                class="btn btn-outline-secondary"
                                title="Hiện mật khẩu"
                                aria-label="Hiện mật khẩu">

                            <i id="bieuTuongMatKhauMoi"
                               class="bi bi-eye">
                            </i>

                        </button>

                    </div>

                    <span asp-validation-for="MatKhauMoi"
                          class="text-danger">
                    </span>

                    <small class="text-secondary">
                        Mật khẩu phải có chữ hoa, chữ thường,
                        số và ký tự đặc biệt.
                    </small>

                </div>

                <div class="mb-4">

                    <label asp-for="XacNhanMatKhauMoi"
                           class="form-label fw-bold">
                    </label>

                    <div class="input-group">

                        <input asp-for="XacNhanMatKhauMoi"
                               class="form-control"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Nhập lại mật khẩu mới" />

                        <button type="button"
                                id="nutHienXacNhanMatKhauMoi"
                                class="btn btn-outline-secondary"
                                title="Hiện mật khẩu"
                                aria-label="Hiện mật khẩu">

                            <i id="bieuTuongXacNhanMatKhauMoi"
                               class="bi bi-eye">
                            </i>

                        </button>

                    </div>

                    <span asp-validation-for="XacNhanMatKhauMoi"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn w-100 text-white fw-bold"
                        style="background: #9b4a00;">

                    <i class="bi bi-check-circle"></i>
                    Xác nhận mật khẩu mới

                </button>

                <div class="text-center mt-4">

                    <a asp-controller="TaiKhoan"
                       asp-action="DangNhap"
                       class="fw-bold text-decoration-none"
                       style="color: #9b4a00;">

                        <i class="bi bi-arrow-left"></i>
                        Quay lại đăng nhập

                    </a>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            function ganSuKienHienMatKhau(
                idOTrong,
                idNut,
                idBieuTuong) {

                const oTrong =
                    document.getElementById(idOTrong);

                const nut =
                    document.getElementById(idNut);

                const bieuTuong =
                    document.getElementById(idBieuTuong);

                if (!oTrong || !nut || !bieuTuong) {
                    return;
                }

                nut.addEventListener("click", function () {

                    const dangAnMatKhau =
                        oTrong.type === "password";

                    oTrong.type =
                        dangAnMatKhau
                            ? "text"
                            : "password";

                    bieuTuong.className =
                        dangAnMatKhau
                            ? "bi bi-eye-slash"
                            : "bi bi-eye";

                    const tieuDeMoi =
                        dangAnMatKhau
                            ? "Ẩn mật khẩu"
                            : "Hiện mật khẩu";

                    nut.title = tieuDeMoi;

                    nut.setAttribute(
                        "aria-label",
                        tieuDeMoi);
                });
            }

            ganSuKienHienMatKhau(
                "MatKhauMoi",
                "nutHienMatKhauMoi",
                "bieuTuongMatKhauMoi");

            ganSuKienHienMatKhau(
                "XacNhanMatKhauMoi",
                "nutHienXacNhanMatKhauMoi",
                "bieuTuongXacNhanMatKhauMoi");
        });
    </script>
}
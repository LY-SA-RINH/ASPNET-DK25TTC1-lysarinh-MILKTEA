@model MilkTea.Web.Models.DangKyViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<section class="container"
         style="max-width: 620px;
    padding-top: 135px;
    padding-bottom: 70px;">

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4 p-md-5">

            <h1 class="text-center fw-bold mb-2"
                style="color: #4a1f08;">
                Đăng ký tài khoản
            </h1>

            <p class="text-center text-secondary mb-4">
                Tạo tài khoản khách hàng tại MilkTea House.
            </p>

            <form asp-controller="TaiKhoan"
                  asp-action="DangKy"
                  method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label asp-for="HoTen"
                           class="form-label fw-bold">
                    </label>

                    <input asp-for="HoTen"
                           class="form-control"
                           autocomplete="name"
                           placeholder="Nhập họ tên" />

                    <span asp-validation-for="HoTen"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Email"
                           class="form-label fw-bold">
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           type="email"
                           autocomplete="email"
                           placeholder="Nhập email" />

                    <span asp-validation-for="Email"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="SoDienThoai"
                           class="form-label fw-bold">
                    </label>

                    <input asp-for="SoDienThoai"
                           class="form-control"
                           type="tel"
                           autocomplete="tel"
                           placeholder="Nhập số điện thoại" />

                    <span asp-validation-for="SoDienThoai"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="MatKhau"
                           class="form-label fw-bold">
                    </label>

                    <div class="input-group">

                        <input asp-for="MatKhau"
                               class="form-control"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Nhập mật khẩu" />

                        <button type="button"
                                id="nutHienMatKhau"
                                class="btn btn-outline-secondary"
                                title="Hiện mật khẩu"
                                aria-label="Hiện mật khẩu">

                            <i id="bieuTuongMatKhau"
                               class="bi bi-eye">
                            </i>

                        </button>

                    </div>

                    <span asp-validation-for="MatKhau"
                          class="text-danger">
                    </span>

                    <small class="text-secondary">
                        Mật khẩu phải có chữ hoa, chữ thường,
                        số và ký tự đặc biệt.
                    </small>

                </div>

                <div class="mb-4">

                    <label asp-for="XacNhanMatKhau"
                           class="form-label fw-bold">
                    </label>

                    <div class="input-group">

                        <input asp-for="XacNhanMatKhau"
                               class="form-control"
                               type="password"
                               autocomplete="new-password"
                               placeholder="Nhập lại mật khẩu" />

                        <button type="button"
                                id="nutHienXacNhanMatKhau"
                                class="btn btn-outline-secondary"
                                title="Hiện mật khẩu"
                                aria-label="Hiện mật khẩu">

                            <i id="bieuTuongXacNhanMatKhau"
                               class="bi bi-eye">
                            </i>

                        </button>

                    </div>

                    <span asp-validation-for="XacNhanMatKhau"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn w-100 text-white fw-bold"
                        style="background: #9b4a00;">

                    <i class="bi bi-person-plus"></i>
                    Đăng ký

                </button>

                <div class="text-center mt-4">

                    Đã có tài khoản?

                    <a asp-controller="TaiKhoan"
                       asp-action="DangNhap"
                       class="fw-bold text-decoration-none"
                       style="color: #9b4a00;">
                        Đăng nhập
                    </a>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            function ganSuKienHienMatKhau(
                idOTrong,
                idNut,
                idBieuTuong) {

                const oTrong =
                    document.getElementById(idOTrong);

                const nut =
                    document.getElementById(idNut);

                const bieuTuong =
                    document.getElementById(idBieuTuong);

                if (!oTrong || !nut || !bieuTuong) {
                    return;
                }

                nut.addEventListener("click", function () {

                    const dangAnMatKhau =
                        oTrong.type === "password";

                    oTrong.type =
                        dangAnMatKhau
                            ? "text"
                            : "password";

                    bieuTuong.className =
                        dangAnMatKhau
                            ? "bi bi-eye-slash"
                            : "bi bi-eye";

                    const tieuDeMoi =
                        dangAnMatKhau
                            ? "Ẩn mật khẩu"
                            : "Hiện mật khẩu";

                    nut.title = tieuDeMoi;

                    nut.setAttribute(
                        "aria-label",
                        tieuDeMoi);
                });
            }

            ganSuKienHienMatKhau(
                "MatKhau",
                "nutHienMatKhau",
                "bieuTuongMatKhau");

            ganSuKienHienMatKhau(
                "XacNhanMatKhau",
                "nutHienXacNhanMatKhau",
                "bieuTuongXacNhanMatKhau");
        });
    </script>
}
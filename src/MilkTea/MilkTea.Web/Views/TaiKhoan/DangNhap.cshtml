@model MilkTea.Web.Models.DangNhapViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="container"
         style="max-width: 560px;
    padding-top: 145px;
    padding-bottom: 80px;">

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">

            <h1 class="text-center fw-bold mb-2"
                style="color: #4a1f08;">
                Đăng nhập
            </h1>

            <p class="text-center text-secondary mb-4">
                Đăng nhập vào MilkTea House.
            </p>

            @if (TempData["Loi"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Loi"]
                </div>
            }

            <form asp-controller="TaiKhoan"
                  asp-action="DangNhap"
                  method="post">

                <input asp-for="ReturnUrl"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label asp-for="Email"
                           class="form-label fw-bold">
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           type="email"
                           autocomplete="email"
                           placeholder="Nhập email" />

                    <span asp-validation-for="Email"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="MatKhau"
                           class="form-label fw-bold">
                    </label>

                    <div class="input-group">

                        <input asp-for="MatKhau"
                               class="form-control"
                               type="password"
                               autocomplete="current-password"
                               placeholder="Nhập mật khẩu" />

                        <button type="button"
                                id="nutHienMatKhauDangNhap"
                                class="btn btn-outline-secondary"
                                title="Hiện mật khẩu"
                                aria-label="Hiện mật khẩu">

                            <i id="bieuTuongMatKhauDangNhap"
                               class="bi bi-eye">
                            </i>

                        </button>

                    </div>

                    <span asp-validation-for="MatKhau"
                          class="text-danger">
                    </span>

                </div>

                <div class="d-flex justify-content-between
                    align-items-center mb-4">

                    <div class="form-check">

                        <input asp-for="GhiNhoDangNhap"
                               class="form-check-input" />

                        <label asp-for="GhiNhoDangNhap"
                               class="form-check-label">
                        </label>

                    </div>

                    <a asp-controller="TaiKhoan"
                       asp-action="QuenMatKhau"
                       class="fw-bold text-decoration-none"
                       style="color: #9b4a00;">
                        Quên mật khẩu?
                    </a>

                </div>

                <button type="submit"
                        class="btn w-100 text-white fw-bold"
                        style="background: #9b4a00;">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Đăng nhập
                </button>

                <div class="text-center mt-4">

                    Chưa có tài khoản?

                    <a asp-controller="TaiKhoan"
                       asp-action="DangKy"
                       class="fw-bold text-decoration-none"
                       style="color: #9b4a00;">
                        Đăng ký
                    </a>

                </div>

            </form>

        </div>
    </div>

</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const oMatKhau =
                document.getElementById("MatKhau");

            const nutHienMatKhau =
                document.getElementById(
                    "nutHienMatKhauDangNhap");

            const bieuTuong =
                document.getElementById(
                    "bieuTuongMatKhauDangNhap");

            if (!oMatKhau ||
                !nutHienMatKhau ||
                !bieuTuong) {
                return;
            }

            nutHienMatKhau.addEventListener(
                "click",
                function () {

                    const dangAnMatKhau =
                        oMatKhau.type === "password";

                    oMatKhau.type =
                        dangAnMatKhau
                            ? "text"
                            : "password";

                    bieuTuong.className =
                        dangAnMatKhau
                            ? "bi bi-eye-slash"
                            : "bi bi-eye";

                    const tieuDeMoi =
                        dangAnMatKhau
                            ? "Ẩn mật khẩu"
                            : "Hiện mật khẩu";

                    nutHienMatKhau.title =
                        tieuDeMoi;

                    nutHienMatKhau.setAttribute(
                        "aria-label",
                        tieuDeMoi);
                });
        });
    </script>
}
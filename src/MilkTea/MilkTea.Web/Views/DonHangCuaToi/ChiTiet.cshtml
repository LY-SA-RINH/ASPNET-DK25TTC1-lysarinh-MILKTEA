@model MilkTea.Web.Models.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    string LayLopTrangThai(string trangThai)
    {
        return trangThai switch
        {
            "Chờ xác nhận" => "bg-warning text-dark",
            "Đã xác nhận" => "bg-info text-dark",
            "Đang giao" => "bg-primary",
            "Hoàn thành" => "bg-success",
            "Đã hủy" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

<section class="container"
         style="padding-top: 130px;
    padding-bottom: 80px;">

    @if (TempData["ThanhCong"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"
             role="alert">

            <i class="bi bi-check-circle-fill me-2"></i>

            @TempData["ThanhCong"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Đóng">
            </button>

        </div>
    }

    @if (TempData["Loi"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show"
             role="alert">

            <i class="bi bi-exclamation-triangle-fill me-2"></i>

            @TempData["Loi"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Đóng">
            </button>

        </div>
    }

    <div class="d-flex flex-wrap
        justify-content-between
        align-items-center
        gap-3 mb-4">

        <div>
            <h1 class="fw-bold mb-2"
                style="color: #4a1f08;">
                Chi tiết đơn hàng
            </h1>

            <p class="text-secondary mb-0">
                Mã đơn:

                <strong>
                    @($"DH-{Model.DonHangID:D6}")
                </strong>
            </p>
        </div>

        <span class="badge rounded-pill fs-6 px-3 py-2
            @LayLopTrangThai(Model.TrangThai)">
            @Model.TrangThai
        </span>

    </div>

    <div class="row g-4">

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4 mb-4">

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4"
                        style="color: #4a1f08;">
                        Sản phẩm đã đặt
                    </h4>

                    <div class="table-responsive">

                        <table class="table align-middle mb-0">

                            <thead style="background-color: #f7efe8;">
                                <tr>
                                    <th>Sản phẩm</th>

                                    <th class="text-end">
                                        Đơn giá
                                    </th>

                                    <th class="text-center">
                                        Số lượng
                                    </th>

                                    <th class="text-end">
                                        Thành tiền
                                    </th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (ChiTietDonHang chiTiet
                                          in Model.ChiTietDonHangs)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            @chiTiet.TenSanPham
                                        </td>

                                        <td class="text-end">
                                            @chiTiet.DonGia.ToString("N0") ₫
                                        </td>

                                        <td class="text-center">
                                            @chiTiet.SoLuong
                                        </td>

                                        <td class="text-end fw-semibold">
                                            @chiTiet.ThanhTien.ToString("N0") ₫
                                        </td>
                                    </tr>
                                }

                            </tbody>

                            <tfoot>
                                <tr>
                                    <td colspan="3"
                                        class="text-end fw-bold py-3">
                                        Tổng cộng:
                                    </td>

                                    <td class="text-end fw-bold fs-5 py-3"
                                        style="color: #8b4513;">
                                        @Model.TongTien.ToString("N0") ₫
                                    </td>
                                </tr>
                            </tfoot>

                        </table>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 mb-4">

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4"
                        style="color: #4a1f08;">
                        Thông tin giao hàng
                    </h4>

                    <div class="mb-3">
                        <div class="text-secondary small">
                            Người nhận
                        </div>

                        <div class="fw-semibold">
                            @Model.HoTen
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-secondary small">
                            Số điện thoại
                        </div>

                        <div class="fw-semibold">
                            @Model.SoDienThoai
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-secondary small">
                            Địa chỉ
                        </div>

                        <div class="fw-semibold">
                            @Model.DiaChi
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-secondary small">
                            Ngày đặt
                        </div>

                        <div class="fw-semibold">
                            @Model.NgayDat.ToString(
                                "dd/MM/yyyy HH:mm")
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-secondary small">
                            Phương thức thanh toán
                        </div>

                        <div class="fw-semibold">
                            @Model.PhuongThucThanhToan
                        </div>
                    </div>

                    <div>
                        <div class="text-secondary small">
                            Ghi chú
                        </div>

                        <div class="fw-semibold">
                            @(string.IsNullOrWhiteSpace(Model.GhiChu)
                                ? "Không có ghi chú"
                                : Model.GhiChu)
                        </div>
                    </div>

                </div>

            </div>

            @if (Model.TrangThai == "Chờ xác nhận")
            {
                <div class="card border-danger shadow-sm rounded-4 mb-3">

                    <div class="card-body p-4">

                        <h5 class="fw-bold text-danger mb-2">
                            Hủy đơn hàng
                        </h5>

                        <p class="text-secondary small mb-3">
                            Bạn chỉ có thể hủy đơn khi đơn hàng
                            chưa được nhân viên xác nhận.
                        </p>

                        <form asp-controller="DonHangCuaToi"
                              asp-action="HuyDonHang"
                              method="post"
                              onsubmit="return confirm(
                            'Bạn có chắc chắn muốn hủy đơn hàng này không?');">

                            <input type="hidden"
                                   name="id"
                                   value="@Model.DonHangID" />

                            <button type="submit"
                                    class="btn btn-danger w-100 py-2">

                                <i class="bi bi-x-circle me-1"></i>

                                Hủy đơn hàng

                            </button>

                        </form>

                    </div>

                </div>
            }
            else if (Model.TrangThai == "Đã hủy")
            {
                <div class="alert alert-secondary">
                    <i class="bi bi-info-circle me-1"></i>

                    Đơn hàng này đã được hủy.
                </div>
            }
            else if (Model.TrangThai == "Hoàn thành")
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle-fill me-1"></i>

                    Đơn hàng đã được giao thành công.
                </div>
            }
            else if (Model.TrangThai == "Đang giao")
            {
                <div class="alert alert-primary">
                    <i class="bi bi-truck me-1"></i>

                    Đơn hàng đang được giao đến bạn.
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-1"></i>

                    Đơn hàng đã được xác nhận và đang được chuẩn bị.
                </div>
            }

        </div>

    </div>

</section>
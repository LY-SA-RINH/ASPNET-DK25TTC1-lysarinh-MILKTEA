@model List<MilkTea.Web.Models.SanPham>

@{
    string? tuKhoa =
        ViewBag.TuKhoa as string;

    bool dangTimKiem =
        !string.IsNullOrWhiteSpace(tuKhoa);

    ViewData["Title"] = dangTimKiem
        ? $"Tìm kiếm: {tuKhoa}"
        : "Tất cả sản phẩm";

    int trangHienTai = ViewBag.TrangHienTai ?? 1;
    int tongSoTrang = ViewBag.TongSoTrang ?? 0;
    int tongSoSanPham = ViewBag.TongSoSanPham ?? 0;

    int tongSanPhamDangBan =
        ViewBag.TongSanPhamDangBan != null
            ? (int)ViewBag.TongSanPhamDangBan
            : Model.Count(sp => sp.TrangThai);
}

<style>
    .product-page {
        min-height: 100vh;
        padding: 125px 20px 70px;
        background: #fffdfb;
    }

    .product-page-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .product-page-heading {
        margin-bottom: 12px;
        color: #4a1f08;
        font-size: 38px;
        font-weight: 800;
        text-align: center;
    }

    .product-page-description {
        margin-bottom: 38px;
        color: #75655c;
        text-align: center;
    }

        .product-page-description strong {
            color: #9a4c00;
        }

    /* Khu vực tìm kiếm sản phẩm */
    .product-search-card {
        margin-bottom: 32px;
        padding: 20px;
        border: 1px solid #ead3bf;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(78, 39, 12, 0.07);
        scroll-margin-top: 110px;
    }

    .product-search-form {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        gap: 12px;
        align-items: center;
    }

    .product-search-input-wrap {
        position: relative;
        min-width: 0;
    }

        .product-search-input-wrap > i {
            position: absolute;
            top: 50%;
            left: 16px;
            color: #9b765d;
            font-size: 18px;
            transform: translateY(-50%);
            pointer-events: none;
        }

    .product-search-input {
        width: 100%;
        height: 50px;
        padding: 0 16px 0 47px;
        border: 1px solid #d9bfa9;
        border-radius: 12px;
        color: #4d3424;
        background: #fffdfb;
        font-family: inherit;
        font-size: 15px;
        outline: none;
        transition: 0.2s ease;
    }

        .product-search-input:focus {
            border-color: #a34e08;
            box-shadow: 0 0 0 3px rgba(163, 78, 8, 0.12);
        }

    .product-search-button,
    .product-search-reset {
        min-height: 50px;
        padding: 0 18px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        font-family: inherit;
        font-size: 14px;
        font-weight: 800;
        text-decoration: none;
        white-space: nowrap;
        transition: 0.2s ease;
    }

    .product-search-button {
        border: 1px solid #8d3f05;
        color: #ffffff;
        background: #8d3f05;
        cursor: pointer;
    }

        .product-search-button:hover {
            background: #6f2f00;
            border-color: #6f2f00;
        }

    .product-search-reset {
        border: 1px solid #d8b99f;
        color: #784018;
        background: #ffffff;
    }

        .product-search-reset:hover {
            color: #ffffff;
            background: #8d3f05;
            border-color: #8d3f05;
        }

    .product-search-result {
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1px solid #f0e1d5;
        color: #745a48;
        font-size: 14px;
        line-height: 1.6;
    }

        .product-search-result strong {
            color: #934407;
        }

    /* Hai nút trên card sản phẩm */
    .product-card-actions {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 8px;
        width: 100%;
        margin-top: 18px;
    }

    .product-cart-form {
        width: 100%;
        margin: 0;
    }

    .btn-product-detail,
    .btn-product-cart,
    .product-unavailable-message {
        width: 100%;
        min-width: 0;
        min-height: 42px;
        padding: 8px 5px;
        border-radius: 10px;
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        font-family: inherit;
        font-size: 12px;
        font-weight: 800;
        line-height: 1.2;
        text-align: center;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        transition: 0.2s ease;
    }

    .btn-product-detail {
        color: #c9001b;
        background: #ffffff;
        border: 1px solid #d8001d;
    }

        .btn-product-detail:hover {
            color: #ffffff;
            background: #b90019;
            border-color: #b90019;
        }

    .btn-product-cart {
        color: #ffffff;
        background: #d0001b;
        border: 1px solid #d0001b;
        cursor: pointer;
    }

        .btn-product-cart:not(:disabled):hover {
            background: #aa0016;
            border-color: #aa0016;
        }

        .btn-product-cart:disabled {
            opacity: 0.62;
            cursor: not-allowed;
        }

        .btn-product-detail i,
        .btn-product-cart i,
        .product-unavailable-message i {
            flex-shrink: 0;
            font-size: 13px;
        }

    /* Sản phẩm tạm ngưng bán */
    .product-card.temporarily-unavailable {
        position: relative;
        opacity: 0.85;
    }

        .product-card.temporarily-unavailable
        .product-photo {
            filter: grayscale(28%);
        }

    .product-badge.unavailable {
        color: #ffffff;
        background: #6d625c;
    }

    .product-unavailable-message {
        color: #675b54;
        background: #f3f0ee;
        border: 1px solid #d4c7bd;
        cursor: not-allowed;
    }

        .product-unavailable-message.out-of-stock {
            color: #9f2c2c;
            background: #fff0f0;
            border-color: #efc2c2;
        }

    .product-unavailable-note {
        min-height: 38px;
        margin-top: 10px;
        padding: 8px 10px;
        border: 1px solid #ead3c8;
        border-radius: 9px;
        color: #a13a2c;
        background: #fff6f2;
        font-size: 13px;
        font-weight: 800;
        line-height: 1.4;
        text-align: center;
    }

        .product-unavailable-note.out-of-stock {
            color: #a42525;
            background: #fff2f2;
            border-color: #edcccc;
        }

    /* Phân trang */
    .phan-trang-khu-vuc {
        width: 100%;
        margin-top: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .phan-trang-danh-sach {
        margin: 0;
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 7px;
        list-style: none;
        background: #fff8f0;
        border: 1px solid #ecd5bf;
        border-radius: 16px;
        box-shadow: 0 8px 22px rgba(105, 55, 16, 0.08);
    }

        .phan-trang-danh-sach li {
            display: flex;
        }

    .phan-trang-nut,
    .phan-trang-so {
        min-width: 42px;
        height: 42px;
        padding: 0 13px;
        border: 1px solid transparent;
        border-radius: 10px;
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: #6b3108;
        background: #ffffff;
        font-size: 14px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .phan-trang-nut {
        min-width: 108px;
        border-color: #e2c1a1;
    }

    .phan-trang-so {
        border-color: #ead5c1;
    }

        .phan-trang-nut:hover,
        .phan-trang-so:hover {
            color: #ffffff;
            background: #a34e08;
            border-color: #a34e08;
            transform: translateY(-1px);
        }

    .phan-trang-hien-tai {
        color: #ffffff;
        background: #7f3600;
        border-color: #7f3600;
        box-shadow: 0 5px 12px rgba(127, 54, 0, 0.22);
    }

    .phan-trang-vo-hieu {
        color: #b8a79b;
        background: #f5eee8;
        border-color: #eadfd6;
        cursor: not-allowed;
        opacity: 0.7;
    }

    .phan-trang-nut i {
        font-size: 12px;
    }

    /* Trường hợp không có sản phẩm */
    .product-empty {
        padding: 60px 20px;
        border: 1px dashed #dfbd9d;
        border-radius: 18px;
        color: #75523a;
        background: #fff8f0;
        text-align: center;
    }

    .product-empty-icon {
        margin-bottom: 12px;
        display: block;
        color: #bd8b65;
        font-size: 42px;
    }

    .product-empty-title {
        margin-bottom: 7px;
        color: #63391d;
        font-size: 19px;
        font-weight: 850;
    }

    .product-empty-description {
        margin: 0;
        color: #846b5a;
        font-size: 14px;
        line-height: 1.6;
    }

    .product-empty-reset {
        min-height: 44px;
        margin-top: 18px;
        padding: 0 16px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        color: #ffffff;
        background: #8d3f05;
        font-size: 14px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .product-empty-reset:hover {
            color: #ffffff;
            background: #6f2f00;
        }

    @@media (max-width: 700px) {
        .product-search-form {
            grid-template-columns: 1fr;
        }

        .product-search-button,
        .product-search-reset {
            width: 100%;
        }

        .product-card-actions {
            grid-template-columns: 1fr;
        }

        .btn-product-detail,
        .btn-product-cart,
        .product-unavailable-message {
            font-size: 13px;
        }
    }

    @@media (max-width: 520px) {
        .product-page {
            padding: 110px 12px 50px;
        }

        .product-page-heading {
            font-size: 30px;
        }

        .phan-trang-danh-sach {
            width: 100%;
            padding: 7px;
            gap: 5px;
        }

        .phan-trang-nut {
            min-width: 92px;
            padding: 0 8px;
        }

        .phan-trang-nut,
        .phan-trang-so {
            height: 40px;
            font-size: 13px;
        }
    }
</style>

<section class="product-page">

    <div class="product-page-container">

        <h1 class="product-page-heading">
            @(dangTimKiem
                ? "Kết quả tìm kiếm"
                : "Tất cả sản phẩm")
        </h1>

        <p class="product-page-description">

            @if (dangTimKiem)
            {
                <span>
                    Tìm thấy
                    <strong>@tongSoSanPham</strong>
                    sản phẩm phù hợp với từ khóa
                    <strong>“@tuKhoa”</strong>.
                </span>
            }
            else
            {
                <span>
                    MilkTea House hiện có
                    <strong>@tongSoSanPham</strong>
                    sản phẩm, trong đó
                    <strong>@tongSanPhamDangBan</strong>
                    sản phẩm đang được bán.
                </span>
            }

        </p>

        <div id="tim-kiem-san-pham"
             class="product-search-card">

            <form asp-controller="SanPham"
                  asp-action="Index"
                  method="get"
                  class="product-search-form">

                <div class="product-search-input-wrap">

                    <i class="bi bi-search"></i>

                    <input type="search"
                           name="tuKhoa"
                           value="@tuKhoa"
                           class="product-search-input"
                           maxlength="100"
                           autocomplete="off"
                           placeholder="Nhập tên hoặc mô tả sản phẩm..."
                           aria-label="Từ khóa tìm kiếm sản phẩm" />

                </div>

                <button type="submit"
                        class="product-search-button">

                    <i class="bi bi-search"></i>

                    Tìm kiếm

                </button>

                @if (dangTimKiem)
                {
                    <a asp-controller="SanPham"
                       asp-action="Index"
                       asp-fragment="tim-kiem-san-pham"
                       class="product-search-reset">

                        <i class="bi bi-x-circle"></i>

                        Xóa tìm kiếm

                    </a>
                }

            </form>

            @if (dangTimKiem)
            {
                <div class="product-search-result">

                    Đang hiển thị kết quả cho:
                    <strong>“@tuKhoa”</strong>

                </div>
            }

        </div>

        @if (Model != null && Model.Count > 0)
        {
            <div class="product-list">

                @foreach (var item in Model)
                {
                    string hinhAnh =
                        string.IsNullOrWhiteSpace(item.HinhAnh)
                            ? "/images/products/san-pham-mac-dinh.png"
                            : $"/images/products/{item.HinhAnh}";

                    <div class="product-card
                        @(!item.TrangThai
                              ? "temporarily-unavailable"
                              : "")">

                        <div class="product-image">

                            @if (!item.TrangThai)
                            {
                                <span class="product-badge unavailable">

                                    <i class="bi bi-pause-circle"></i>

                                    TẠM NGƯNG BÁN

                                </span>
                            }
                            else if (item.NhanSanPham == 1)
                            {
                                <span class="product-badge hot">

                                    <i class="bi bi-fire"></i>

                                    HOT

                                </span>
                            }
                            else if (item.NhanSanPham == 2)
                            {
                                <span class="product-badge new">
                                    NEW
                                </span>
                            }

                            <img src="@hinhAnh"
                                 alt="@item.TenSanPham"
                                 class="product-photo"
                                 loading="lazy"
                                 onerror="this.onerror=null; this.src='/images/products/san-pham-mac-dinh.png';" />

                        </div>

                        <div class="product-info">

                            <h4>
                                @item.TenSanPham
                            </h4>

                            <div class="product-rating">

                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>

                                <span>
                                    (@item.DanhGia.ToString("0.00"))
                                </span>

                            </div>

                            <div class="product-price">

                                @if (item.GiaGoc.HasValue &&
                                     item.GiaGoc.Value > item.Gia)
                                {
                                    <span class="old-price">
                                        @item.GiaGoc.Value.ToString("N0")đ
                                    </span>
                                }

                                <span class="new-price">
                                    @item.Gia.ToString("N0")đ
                                </span>

                            </div>

                            <div class="product-card-actions">

                                <a asp-controller="SanPham"
                                   asp-action="ChiTiet"
                                   asp-route-id="@item.SanPhamID"
                                   class="btn-product-detail">

                                    <i class="bi bi-eye"></i>

                                    Xem chi tiết

                                </a>

                                @if (!item.TrangThai)
                                {
                                    <div class="product-unavailable-message">

                                        <i class="bi bi-cart-x"></i>

                                        Chưa thể mua

                                    </div>
                                }
                                else if (item.SoLuongTon <= 0)
                                {
                                    <div class="product-unavailable-message
                                        out-of-stock">

                                        <i class="bi bi-cart-x"></i>

                                        Hết hàng

                                    </div>
                                }
                                else
                                {
                                    <form asp-controller="GioHang"
                                          asp-action="Them"
                                          method="post"
                                          class="product-cart-form">

                                        <input type="hidden"
                                               name="id"
                                               value="@item.SanPhamID" />

                                        <input type="hidden"
                                               name="soLuong"
                                               value="1" />

                                        <input type="hidden"
                                               name="returnUrl"
                                               value="@(Context.Request.Path +
                                                                                                                                                      Context.Request.QueryString)" />

                                        <button type="submit"
                                                class="btn-product-cart">

                                            <i class="bi bi-cart3"></i>

                                            Thêm vào giỏ

                                        </button>

                                    </form>
                                }

                            </div>

                            @if (!item.TrangThai)
                            {
                                <div class="product-unavailable-note">

                                    <i class="bi bi-info-circle me-1"></i>

                                    Sản phẩm hiện đang tạm ngưng bán.

                                </div>
                            }
                            else if (item.SoLuongTon <= 0)
                            {
                                <div class="product-unavailable-note
                                    out-of-stock">

                                    <i class="bi bi-exclamation-circle me-1"></i>

                                    Sản phẩm hiện đang tạm hết hàng.

                                </div>
                            }

                        </div>

                    </div>
                }

            </div>

            @if (tongSoTrang > 1)
            {
                <nav class="phan-trang-khu-vuc"
                     aria-label="Phân trang sản phẩm">

                    <ul class="phan-trang-danh-sach">

                        <li>

                            @if (trangHienTai > 1)
                            {
                                <a asp-controller="SanPham"
                                   asp-action="Index"
                                   asp-route-trang="@(trangHienTai - 1)"
                                   asp-route-tuKhoa="@tuKhoa"
                                   class="phan-trang-nut">

                                    <i class="bi bi-chevron-left"></i>

                                    Trang trước

                                </a>
                            }
                            else
                            {
                                <span class="phan-trang-nut
                                    phan-trang-vo-hieu">

                                    <i class="bi bi-chevron-left"></i>

                                    Trang trước

                                </span>
                            }

                        </li>

                        @for (int soTrang = 1;
                              soTrang <= tongSoTrang;
                              soTrang++)
                        {
                            <li>

                                @if (soTrang == trangHienTai)
                                {
                                    <span class="phan-trang-so
                                        phan-trang-hien-tai"
                                          aria-current="page">

                                        @soTrang

                                    </span>
                                }
                                else
                                {
                                    <a asp-controller="SanPham"
                                       asp-action="Index"
                                       asp-route-trang="@soTrang"
                                       asp-route-tuKhoa="@tuKhoa"
                                       class="phan-trang-so">

                                        @soTrang

                                    </a>
                                }

                            </li>
                        }

                        <li>

                            @if (trangHienTai < tongSoTrang)
                            {
                                <a asp-controller="SanPham"
                                   asp-action="Index"
                                   asp-route-trang="@(trangHienTai + 1)"
                                   asp-route-tuKhoa="@tuKhoa"
                                   class="phan-trang-nut">

                                    Trang sau

                                    <i class="bi bi-chevron-right"></i>

                                </a>
                            }
                            else
                            {
                                <span class="phan-trang-nut
                                    phan-trang-vo-hieu">

                                    Trang sau

                                    <i class="bi bi-chevron-right"></i>

                                </span>
                            }

                        </li>

                    </ul>

                </nav>
            }
        }
        else
        {
            <div class="product-empty">

                <i class="bi bi-search product-empty-icon"></i>

                @if (dangTimKiem)
                {
                    <div class="product-empty-title">
                        Không tìm thấy sản phẩm phù hợp
                    </div>

                    <p class="product-empty-description">
                        Không có sản phẩm nào khớp với từ khóa
                        <strong>“@tuKhoa”</strong>.
                        Hãy thử một từ khóa khác.
                    </p>

                    <a asp-controller="SanPham"
                       asp-action="Index"
                       asp-fragment="tim-kiem-san-pham"
                       class="product-empty-reset">

                        <i class="bi bi-arrow-counterclockwise"></i>

                        Xem tất cả sản phẩm

                    </a>
                }
                else
                {
                    <div class="product-empty-title">
                        Hiện chưa có sản phẩm
                    </div>

                    <p class="product-empty-description">
                        Hệ thống chưa có dữ liệu sản phẩm để hiển thị.
                    </p>
                }

            </div>
        }

    </div>

</section>
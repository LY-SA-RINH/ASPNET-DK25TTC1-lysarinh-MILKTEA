@model List<MilkTea.Web.Models.SanPham>

@{
    ViewData["Title"] = "Tất cả sản phẩm";

    int trangHienTai = ViewBag.TrangHienTai ?? 1;
    int tongSoTrang = ViewBag.TongSoTrang ?? 0;
    int tongSoSanPham = ViewBag.TongSoSanPham ?? 0;
}

<style>
    .product-page {
        padding: 125px 20px 70px;
        background: #fffdfb;
        min-height: 100vh;
    }

    .product-page-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .product-page-heading {
        text-align: center;
        margin-bottom: 12px;
        color: #4a1f08;
        font-size: 38px;
        font-weight: 800;
    }

    .product-page-description {
        text-align: center;
        color: #75655c;
        margin-bottom: 38px;
    }

        .product-page-description strong {
            color: #9a4c00;
        }

    /* Hai nút trên card sản phẩm */
    .product-card-actions {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 8px;
        width: 100%;
        margin-top: 18px;
    }

    .btn-product-detail,
    .btn-product-cart {
        width: 100%;
        min-width: 0;
        min-height: 42px;
        padding: 8px 5px;
        border-radius: 10px;
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        font-family: inherit;
        font-size: 12px;
        font-weight: 800;
        line-height: 1.2;
        text-align: center;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        transition: 0.2s ease;
    }

    .btn-product-detail {
        color: #c9001b;
        background: #ffffff;
        border: 1px solid #d8001d;
    }

        .btn-product-detail:hover {
            color: #ffffff;
            background: #b90019;
            border-color: #b90019;
        }

    .btn-product-cart {
        color: #ffffff;
        background: #d0001b;
        border: 1px solid #d0001b;
    }

        .btn-product-cart:not(:disabled):hover {
            background: #aa0016;
            border-color: #aa0016;
        }

        .btn-product-cart:disabled {
            opacity: 0.62;
            cursor: not-allowed;
        }

        .btn-product-detail i,
        .btn-product-cart i {
            flex-shrink: 0;
            font-size: 13px;
        }

    /* Phân trang */
    .phan-trang-khu-vuc {
        width: 100%;
        margin-top: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .phan-trang-danh-sach {
        margin: 0;
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 7px;
        list-style: none;
        background: #fff8f0;
        border: 1px solid #ecd5bf;
        border-radius: 16px;
        box-shadow: 0 8px 22px rgba(105, 55, 16, 0.08);
    }

        .phan-trang-danh-sach li {
            display: flex;
        }

    .phan-trang-nut,
    .phan-trang-so {
        min-width: 42px;
        height: 42px;
        padding: 0 13px;
        border: 1px solid transparent;
        border-radius: 10px;
        box-sizing: border-box;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: #6b3108;
        background: #ffffff;
        font-size: 14px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .phan-trang-nut {
        min-width: 108px;
        border-color: #e2c1a1;
    }

    .phan-trang-so {
        border-color: #ead5c1;
    }

        .phan-trang-nut:hover,
        .phan-trang-so:hover {
            color: #ffffff;
            background: #a34e08;
            border-color: #a34e08;
            transform: translateY(-1px);
        }

    .phan-trang-hien-tai {
        color: #ffffff;
        background: #7f3600;
        border-color: #7f3600;
        box-shadow: 0 5px 12px rgba(127, 54, 0, 0.22);
    }

    .phan-trang-vo-hieu {
        color: #b8a79b;
        background: #f5eee8;
        border-color: #eadfd6;
        cursor: not-allowed;
        opacity: 0.7;
    }

    .phan-trang-nut i {
        font-size: 12px;
    }

    /* Trường hợp không có sản phẩm */
    .product-empty {
        padding: 60px 20px;
        border: 1px dashed #dfbd9d;
        border-radius: 18px;
        background: #fff8f0;
        text-align: center;
        color: #75523a;
        font-size: 18px;
    }

    @@media (max-width: 700px) {
        .product-card-actions {
            grid-template-columns: 1fr;
        }

        .btn-product-detail,
        .btn-product-cart {
            font-size: 13px;
        }
    }

    @@media (max-width: 520px) {
        .product-page {
            padding: 110px 12px 50px;
        }

        .product-page-heading {
            font-size: 30px;
        }

        .phan-trang-danh-sach {
            width: 100%;
            padding: 7px;
            gap: 5px;
        }

        .phan-trang-nut {
            min-width: 92px;
            padding: 0 8px;
        }

        .phan-trang-nut,
        .phan-trang-so {
            height: 40px;
            font-size: 13px;
        }
    }
</style>

<section class="product-page">

    <div class="product-page-container">

        <h1 class="product-page-heading">
            Tất cả sản phẩm
        </h1>

        <p class="product-page-description">
            Hiện có
            <strong>@tongSoSanPham</strong>
            sản phẩm đang được bán tại MilkTea House.
        </p>

        @if (Model != null && Model.Count > 0)
        {
            <div class="product-list">

                @foreach (var item in Model)
                {
                    <div class="product-card">

                        <div class="product-image">

                            @if (item.NhanSanPham == 1)
                            {
                                <span class="product-badge hot">
                                    <i class="bi bi-fire"></i>
                                    HOT
                                </span>
                            }
                            else if (item.NhanSanPham == 2)
                            {
                                <span class="product-badge new">
                                    NEW
                                </span>
                            }

                            <img src="/images/products/@item.HinhAnh"
                                 alt="@item.TenSanPham"
                                 class="product-photo"
                                 loading="lazy"
                                 onerror="this.onerror=null; this.src='/images/products/san-pham-mac-dinh.png';" />

                        </div>

                        <div class="product-info">

                            <h4>@item.TenSanPham</h4>

                            <div class="product-rating">

                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>

                                <span>
                                    (@item.DanhGia.ToString("0.00"))
                                </span>

                            </div>

                            <div class="product-price">

                                @if (item.GiaGoc.HasValue &&
                                     item.GiaGoc.Value > item.Gia)
                                {
                                    <span class="old-price">
                                        @item.GiaGoc.Value.ToString("N0")đ
                                    </span>
                                }

                                <span class="new-price">
                                    @item.Gia.ToString("N0")đ
                                </span>

                            </div>

                            <div class="product-card-actions">

                                <a asp-controller="SanPham"
                                   asp-action="ChiTiet"
                                   asp-route-id="@item.SanPhamID"
                                   class="btn-product-detail">

                                    <i class="bi bi-eye"></i>
                                    Xem chi tiết
                                </a>

                                <button type="button"
                                        class="btn-product-cart"
                                        title="Chức năng giỏ hàng sẽ được xây dựng ở bước tiếp theo"
                                        disabled>

                                    <i class="bi bi-cart3"></i>
                                    Thêm vào giỏ
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>

            @if (tongSoTrang > 1)
            {
                <nav class="phan-trang-khu-vuc"
                     aria-label="Phân trang sản phẩm">

                    <ul class="phan-trang-danh-sach">

                        <li>
                            @if (trangHienTai > 1)
                            {
                                <a asp-controller="SanPham"
                                   asp-action="Index"
                                   asp-route-trang="@(trangHienTai - 1)"
                                   class="phan-trang-nut">

                                    <i class="bi bi-chevron-left"></i>
                                    Trang trước
                                </a>
                            }
                            else
                            {
                                <span class="phan-trang-nut phan-trang-vo-hieu">
                                    <i class="bi bi-chevron-left"></i>
                                    Trang trước
                                </span>
                            }
                        </li>

                        @for (int soTrang = 1; soTrang <= tongSoTrang; soTrang++)
                        {
                            <li>
                                @if (soTrang == trangHienTai)
                                {
                                    <span class="phan-trang-so phan-trang-hien-tai"
                                          aria-current="page">
                                        @soTrang
                                    </span>
                                }
                                else
                                {
                                    <a asp-controller="SanPham"
                                       asp-action="Index"
                                       asp-route-trang="@soTrang"
                                       class="phan-trang-so">
                                        @soTrang
                                    </a>
                                }
                            </li>
                        }

                        <li>
                            @if (trangHienTai < tongSoTrang)
                            {
                                <a asp-controller="SanPham"
                                   asp-action="Index"
                                   asp-route-trang="@(trangHienTai + 1)"
                                   class="phan-trang-nut">

                                    Trang sau
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            }
                            else
                            {
                                <span class="phan-trang-nut phan-trang-vo-hieu">
                                    Trang sau
                                    <i class="bi bi-chevron-right"></i>
                                </span>
                            }
                        </li>

                    </ul>

                </nav>
            }
        }
        else
        {
            <div class="product-empty">
                Hiện chưa có sản phẩm nào đang được bán.
            </div>
        }

    </div>

</section>
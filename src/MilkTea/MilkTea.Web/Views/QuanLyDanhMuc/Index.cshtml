@using MilkTea.Web.Models
@model MilkTea.Web.Models.QuanLyDanhMucViewModel

@{
    ViewData["Title"] = "Quản lý danh mục";
}

<style>
    .category-admin-page {
        min-height: 100vh;
        padding: 125px 20px 70px;
        background: #fffdfb;
    }

    .category-admin-container {
        max-width: 1250px;
        margin: 0 auto;
    }

    .category-admin-heading-area {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 28px;
    }

    .category-admin-heading {
        margin: 0 0 8px;
        color: #4a1f08;
        font-size: 36px;
        font-weight: 800;
    }

    .category-admin-description {
        margin: 0;
        color: #75655c;
    }

    .category-admin-add-button {
        min-height: 46px;
        padding: 0 18px;
        border: 1px solid #278453;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: #ffffff;
        background: #278453;
        font-weight: 800;
        text-decoration: none;
        white-space: nowrap;
        transition: 0.2s ease;
    }

        .category-admin-add-button:hover {
            color: #ffffff;
            background: #17653b;
            border-color: #17653b;
        }

    .category-admin-statistics {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .category-admin-statistic {
        padding: 20px;
        border: 1px solid #ecd7c4;
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 7px 20px rgba(91, 47, 15, 0.06);
    }

    .category-admin-statistic-label {
        margin-bottom: 7px;
        color: #7a675b;
        font-size: 14px;
        font-weight: 700;
    }

    .category-admin-statistic-value {
        color: #4a1f08;
        font-size: 28px;
        font-weight: 800;
    }

    .category-admin-filter {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(180px, 230px) auto auto;
        gap: 12px;
        padding: 20px;
        margin-bottom: 24px;
        border: 1px solid #ecd7c4;
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 7px 20px rgba(91, 47, 15, 0.06);
    }

        .category-admin-filter input,
        .category-admin-filter select {
            width: 100%;
            min-height: 45px;
            padding: 9px 12px;
            border: 1px solid #d9bfa7;
            border-radius: 10px;
            color: #4a2b19;
            background: #ffffff;
            outline: none;
        }

            .category-admin-filter input:focus,
            .category-admin-filter select:focus {
                border-color: #9b4a00;
                box-shadow: 0 0 0 3px rgba(155, 74, 0, 0.12);
            }

    .category-admin-filter-button,
    .category-admin-reset-button {
        min-height: 45px;
        padding: 0 18px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        font-weight: 800;
        text-decoration: none;
        white-space: nowrap;
    }

    .category-admin-filter-button {
        border: 1px solid #9b4a00;
        color: #ffffff;
        background: #9b4a00;
        cursor: pointer;
    }

        .category-admin-filter-button:hover {
            background: #743500;
            border-color: #743500;
        }

    .category-admin-reset-button {
        border: 1px solid #d3ad8b;
        color: #754018;
        background: #ffffff;
    }

        .category-admin-reset-button:hover {
            color: #ffffff;
            background: #9b4a00;
            border-color: #9b4a00;
        }

    .category-admin-result {
        margin-bottom: 12px;
        color: #675247;
        font-weight: 700;
    }

    .category-admin-card {
        overflow: hidden;
        border: 1px solid #ecd7c4;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 10px 28px rgba(91, 47, 15, 0.07);
    }

    .category-admin-table {
        width: 100%;
        margin: 0;
        border-collapse: collapse;
    }

        .category-admin-table th {
            padding: 15px 14px;
            color: #4a1f08;
            background: #fff4e8;
            font-size: 14px;
            font-weight: 800;
            text-align: left;
            white-space: nowrap;
        }

        .category-admin-table td {
            padding: 14px;
            border-top: 1px solid #f0e3d8;
            color: #4c392e;
            vertical-align: middle;
        }

    .category-admin-name {
        min-width: 180px;
        color: #4a1f08;
        font-weight: 800;
    }

    .category-admin-code {
        margin-top: 4px;
        color: #8a776c;
        font-size: 12px;
    }

    .category-admin-description-text {
        min-width: 220px;
        max-width: 360px;
        color: #6e5c52;
        line-height: 1.5;
    }

    .category-admin-product-count {
        min-width: 72px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 7px 11px;
        border-radius: 999px;
        color: #76502d;
        background: #fff1df;
        font-size: 13px;
        font-weight: 800;
        white-space: nowrap;
    }

    .category-admin-date {
        color: #715e53;
        white-space: nowrap;
    }

    .category-admin-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        white-space: nowrap;
    }

        .category-admin-badge.active {
            color: #17653b;
            background: #e5f7ec;
        }

        .category-admin-badge.inactive {
            color: #8b2828;
            background: #fdeaea;
        }

    .category-admin-actions {
        min-width: 230px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .category-admin-edit-button {
        min-width: 88px;
        min-height: 38px;
        padding: 6px 12px;
        border: 1px solid #c08035;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: #85500f;
        background: #fffaf2;
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        white-space: nowrap;
        transition: 0.2s ease;
    }

        .category-admin-edit-button:hover {
            color: #ffffff;
            background: #a96518;
            border-color: #a96518;
        }

    .category-admin-status-button {
        min-width: 108px;
        min-height: 38px;
        padding: 6px 12px;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 800;
        cursor: pointer;
        white-space: nowrap;
        transition: 0.2s ease;
    }

        .category-admin-status-button.stop {
            border: 1px solid #d34b4b;
            color: #a52222;
            background: #ffffff;
        }

            .category-admin-status-button.stop:hover {
                color: #ffffff;
                background: #c73434;
            }

        .category-admin-status-button.open {
            border: 1px solid #278453;
            color: #17653b;
            background: #ffffff;
        }

            .category-admin-status-button.open:hover {
                color: #ffffff;
                background: #278453;
            }

    .category-admin-empty {
        padding: 55px 20px !important;
        color: #765744;
        text-align: center;
    }

    .category-admin-pagination {
        display: flex;
        justify-content: center;
        gap: 7px;
        margin-top: 28px;
        flex-wrap: wrap;
    }

    .category-admin-page-link {
        min-width: 42px;
        height: 42px;
        padding: 0 12px;
        border: 1px solid #dfc5ae;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #744019;
        background: #ffffff;
        font-weight: 800;
        text-decoration: none;
    }

        .category-admin-page-link:hover,
        .category-admin-page-link.current {
            color: #ffffff;
            background: #8b4108;
            border-color: #8b4108;
        }

    @@media (max-width: 1050px) {
        .category-admin-statistics {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .category-admin-filter {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 650px) {
        .category-admin-page {
            padding: 110px 12px 45px;
        }

        .category-admin-heading-area {
            flex-direction: column;
        }

        .category-admin-heading {
            font-size: 30px;
        }

        .category-admin-add-button {
            width: 100%;
        }

        .category-admin-statistics,
        .category-admin-filter {
            grid-template-columns: 1fr;
        }
    }
</style>

<section class="category-admin-page">

    <div class="category-admin-container">

        <div class="category-admin-heading-area">

            <div>

                <h1 class="category-admin-heading">
                    Quản lý danh mục
                </h1>

                <p class="category-admin-description">
                    Theo dõi và quản lý các nhóm sản phẩm của MilkTea House.
                </p>

            </div>

            <a asp-controller="QuanLyDanhMuc"
               asp-action="Them"
               class="category-admin-add-button">

                <i class="bi bi-plus-circle"></i>

                Thêm danh mục

            </a>

        </div>

        @if (TempData["ThanhCong"] != null)
        {
            <div class="alert alert-success
                alert-dismissible fade show"
                 role="alert">

                <i class="bi bi-check-circle-fill me-2"></i>

                @TempData["ThanhCong"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Đóng">
                </button>

            </div>
        }

        @if (TempData["Loi"] != null)
        {
            <div class="alert alert-danger
                alert-dismissible fade show"
                 role="alert">

                <i class="bi bi-exclamation-triangle-fill me-2"></i>

                @TempData["Loi"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Đóng">
                </button>

            </div>
        }

        <div class="category-admin-statistics">

            <div class="category-admin-statistic">

                <div class="category-admin-statistic-label">
                    Tất cả danh mục
                </div>

                <div class="category-admin-statistic-value">
                    @Model.TongTatCaDanhMuc
                </div>

            </div>

            <div class="category-admin-statistic">

                <div class="category-admin-statistic-label">
                    Đang hoạt động
                </div>

                <div class="category-admin-statistic-value">
                    @Model.TongDanhMucHoatDong
                </div>

            </div>

            <div class="category-admin-statistic">

                <div class="category-admin-statistic-label">
                    Tạm ngưng
                </div>

                <div class="category-admin-statistic-value">
                    @Model.TongDanhMucTamNgung
                </div>

            </div>

            <div class="category-admin-statistic">

                <div class="category-admin-statistic-label">
                    Danh mục có sản phẩm
                </div>

                <div class="category-admin-statistic-value">
                    @Model.TongDanhMucCoSanPham
                </div>

            </div>

        </div>

        <form asp-controller="QuanLyDanhMuc"
              asp-action="Index"
              method="get"
              class="category-admin-filter">

            <input type="text"
                   name="tuKhoa"
                   value="@Model.TuKhoa"
                   placeholder="Tìm theo tên hoặc mô tả danh mục..." />

            <select name="trangThai">

                @if (string.IsNullOrWhiteSpace(Model.TrangThai))
                {
                    <option value="" selected>
                        Tất cả trạng thái
                    </option>
                }
                else
                {
                    <option value="">
                        Tất cả trạng thái
                    </option>
                }

                @if (Model.TrangThai == "hoat-dong")
                {
                    <option value="hoat-dong" selected>
                        Đang hoạt động
                    </option>
                }
                else
                {
                    <option value="hoat-dong">
                        Đang hoạt động
                    </option>
                }

                @if (Model.TrangThai == "tam-ngung")
                {
                    <option value="tam-ngung" selected>
                        Tạm ngưng
                    </option>
                }
                else
                {
                    <option value="tam-ngung">
                        Tạm ngưng
                    </option>
                }

            </select>

            <button type="submit"
                    class="category-admin-filter-button">

                <i class="bi bi-search"></i>

                Lọc

            </button>

            <a asp-controller="QuanLyDanhMuc"
               asp-action="Index"
               class="category-admin-reset-button">

                <i class="bi bi-arrow-counterclockwise"></i>

                Đặt lại

            </a>

        </form>

        <div class="category-admin-result">
            Tìm thấy @Model.TongKetQua danh mục.
        </div>

        <div class="category-admin-card">

            <div class="table-responsive">

                <table class="category-admin-table">

                    <thead>
                        <tr>
                            <th>Danh mục</th>
                            <th>Mô tả</th>
                            <th>Sản phẩm</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model.DanhMucs.Count == 0)
                        {
                            <tr>
                                <td colspan="6"
                                    class="category-admin-empty">

                                    <i class="bi bi-folder-x"
                                       style="font-size: 34px;">
                                    </i>

                                    <div class="mt-2">
                                        Không tìm thấy danh mục phù hợp.
                                    </div>

                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (DanhMuc danhMuc in Model.DanhMucs)
                            {
                                int soSanPham =
                                    Model.SoSanPhamTheoDanhMuc.ContainsKey(
                                        danhMuc.DanhMucID)
                                    ? Model.SoSanPhamTheoDanhMuc[
                                        danhMuc.DanhMucID]
                                    : 0;

                                string thongBaoXacNhan =
                                    danhMuc.TrangThai
                                    ? "Bạn có chắc muốn tạm ngưng danh mục này? Sản phẩm cũ vẫn được giữ nguyên."
                                    : "Bạn có chắc muốn kích hoạt lại danh mục này?";

                                <tr>

                                    <td>

                                        <div class="category-admin-name">
                                            @danhMuc.TenDanhMuc
                                        </div>

                                        <div class="category-admin-code">
                                            DM-@danhMuc.DanhMucID.ToString("D4")
                                        </div>

                                    </td>

                                    <td>

                                        <div class="category-admin-description-text">

                                            @if (string.IsNullOrWhiteSpace(
                                                danhMuc.MoTa))
                                            {
                                                <span class="text-secondary">
                                                    Chưa có mô tả
                                                </span>
                                            }
                                            else
                                            {
                                                @danhMuc.MoTa
                                            }

                                        </div>

                                    </td>

                                    <td>

                                        <span class="category-admin-product-count">

                                            <i class="bi bi-cup-straw"></i>

                                            @soSanPham sản phẩm

                                        </span>

                                    </td>

                                    <td class="category-admin-date">
                                        @danhMuc.NgayTao.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>

                                        @if (danhMuc.TrangThai)
                                        {
                                            <span class="category-admin-badge active">
                                                Đang hoạt động
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="category-admin-badge inactive">
                                                Tạm ngưng
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <div class="category-admin-actions">

                                            <a asp-controller="QuanLyDanhMuc"
                                               asp-action="Sua"
                                               asp-route-id="@danhMuc.DanhMucID"
                                               class="category-admin-edit-button"
                                               title="Sửa thông tin danh mục">

                                                <i class="bi bi-pencil-square"></i>

                                                Sửa

                                            </a>

                                            <form asp-controller="QuanLyDanhMuc"
                                                  asp-action="CapNhatTrangThai"
                                                  method="post"
                                                  onsubmit="return confirm('@thongBaoXacNhan');">

                                                <input type="hidden"
                                                       name="id"
                                                       value="@danhMuc.DanhMucID" />

                                                <input type="hidden"
                                                       name="tuKhoa"
                                                       value="@Model.TuKhoa" />

                                                <input type="hidden"
                                                       name="trangThai"
                                                       value="@Model.TrangThai" />

                                                <input type="hidden"
                                                       name="trang"
                                                       value="@Model.TrangHienTai" />

                                                @if (danhMuc.TrangThai)
                                                {
                                                    <button type="submit"
                                                            name="thaoTac"
                                                            value="tam-ngung"
                                                            class="category-admin-status-button stop">

                                                        <i class="bi bi-pause-circle"></i>

                                                        Tạm ngưng

                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit"
                                                            name="thaoTac"
                                                            value="kich-hoat"
                                                            class="category-admin-status-button open">

                                                        <i class="bi bi-play-circle"></i>

                                                        Kích hoạt

                                                    </button>
                                                }

                                            </form>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

        @if (Model.TongSoTrang > 1)
        {
            <nav class="category-admin-pagination"
                 aria-label="Phân trang quản lý danh mục">

                @for (int soTrang = 1;
                      soTrang <= Model.TongSoTrang;
                      soTrang++)
                {
                    <a asp-controller="QuanLyDanhMuc"
                       asp-action="Index"
                       asp-route-tuKhoa="@Model.TuKhoa"
                       asp-route-trangThai="@Model.TrangThai"
                       asp-route-trang="@soTrang"
                       class="category-admin-page-link
                        @(soTrang == Model.TrangHienTai
                           ? "current"
                           : "")">

                        @soTrang

                    </a>
                }

            </nav>
        }

    </div>

</section>
@model MilkTea.Web.Models.SuaDanhMucViewModel

@{
    ViewData["Title"] = "Sửa danh mục";
}

<style>
    .edit-category-page {
        min-height: 100vh;
        padding: 125px 20px 70px;
        background: #fffdfb;
    }

    .edit-category-container {
        max-width: 820px;
        margin: 0 auto;
    }

    .edit-category-heading-area {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 28px;
    }

    .edit-category-heading {
        margin: 0 0 8px;
        color: #4a1f08;
        font-size: 36px;
        font-weight: 800;
    }

    .edit-category-description {
        margin: 0;
        color: #75655c;
    }

    .edit-category-code {
        padding: 10px 14px;
        border: 1px solid #e0c4aa;
        border-radius: 10px;
        color: #704522;
        background: #fff7ed;
        font-weight: 800;
        white-space: nowrap;
    }

    .edit-category-card {
        padding: 30px;
        border: 1px solid #ecd7c4;
        border-radius: 20px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(91, 47, 15, 0.08);
    }

    .edit-category-validation {
        margin-bottom: 20px;
        padding: 12px 15px;
        border-radius: 10px;
        color: #a72020;
        background: #fff1f1;
        font-weight: 700;
    }

        .edit-category-validation:empty {
            display: none;
        }

    .edit-category-field {
        margin-bottom: 20px;
    }

        .edit-category-field > label {
            display: block;
            margin-bottom: 7px;
            color: #57331e;
            font-weight: 800;
        }

    .edit-category-required {
        color: #be2020;
    }

    .edit-category-field input,
    .edit-category-field textarea {
        width: 100%;
        min-height: 48px;
        padding: 10px 13px;
        border: 1px solid #d9bfa7;
        border-radius: 11px;
        box-sizing: border-box;
        color: #3f2a1e;
        background: #ffffff;
        font-family: inherit;
        outline: none;
    }

    .edit-category-field textarea {
        min-height: 145px;
        resize: vertical;
    }

        .edit-category-field input:focus,
        .edit-category-field textarea:focus {
            border-color: #9b4a00;
            box-shadow: 0 0 0 3px rgba(155, 74, 0, 0.12);
        }

    .edit-category-error {
        display: block;
        margin-top: 5px;
        color: #be2020;
        font-size: 13px;
        font-weight: 700;
    }

    .edit-category-help {
        display: block;
        margin-top: 6px;
        color: #806f65;
        font-size: 13px;
        line-height: 1.5;
    }

    .edit-category-information {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .edit-category-information-item {
        padding: 15px;
        border: 1px solid #ead3bd;
        border-radius: 12px;
        background: #fffaf5;
    }

    .edit-category-information-label {
        margin-bottom: 5px;
        color: #806b5e;
        font-size: 13px;
        font-weight: 700;
    }

    .edit-category-information-value {
        color: #4a1f08;
        font-size: 20px;
        font-weight: 800;
    }

    .edit-category-status {
        min-height: 52px;
        padding: 12px 14px;
        border: 1px solid #d9bfa7;
        border-radius: 11px;
        display: flex;
        align-items: center;
        gap: 11px;
        background: #fffaf5;
    }

        .edit-category-status input {
            width: 19px;
            height: 19px;
            min-height: auto;
            margin: 0;
            cursor: pointer;
        }

        .edit-category-status label {
            margin: 0;
            color: #57331e;
            font-weight: 800;
            cursor: pointer;
        }

    .edit-category-warning {
        margin-top: 10px;
        padding: 11px 13px;
        border-radius: 10px;
        color: #755233;
        background: #fff1df;
        font-size: 13px;
        line-height: 1.6;
    }

    .edit-category-actions {
        display: flex;
        gap: 12px;
        margin-top: 28px;
    }

    .edit-category-submit,
    .edit-category-back {
        min-height: 50px;
        padding: 0 22px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .edit-category-submit {
        flex: 1;
        border: 1px solid #9b4a00;
        color: #ffffff;
        background: #9b4a00;
        cursor: pointer;
    }

        .edit-category-submit:hover {
            background: #743500;
            border-color: #743500;
        }

    .edit-category-back {
        border: 1px solid #d0aa87;
        color: #754018;
        background: #ffffff;
    }

        .edit-category-back:hover {
            color: #ffffff;
            background: #8a4a18;
            border-color: #8a4a18;
        }

    @@media (max-width: 650px) {
        .edit-category-page {
            padding: 110px 12px 45px;
        }

        .edit-category-heading-area {
            flex-direction: column;
        }

        .edit-category-heading {
            font-size: 30px;
        }

        .edit-category-card {
            padding: 20px;
        }

        .edit-category-information {
            grid-template-columns: 1fr;
        }

        .edit-category-actions {
            flex-direction: column;
        }

        .edit-category-submit,
        .edit-category-back {
            width: 100%;
        }
    }
</style>

<section class="edit-category-page">

    <div class="edit-category-container">

        <div class="edit-category-heading-area">

            <div>

                <h1 class="edit-category-heading">
                    Sửa danh mục
                </h1>

                <p class="edit-category-description">
                    Cập nhật thông tin nhóm sản phẩm của MilkTea House.
                </p>

            </div>

            <div class="edit-category-code">
                DM-@Model.DanhMucID.ToString("D4")
            </div>

        </div>

        <div class="edit-category-card">

            <form asp-controller="QuanLyDanhMuc"
                  asp-action="Sua"
                  method="post">

                <input asp-for="DanhMucID"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="edit-category-validation">
                </div>

                <div class="edit-category-information">

                    <div class="edit-category-information-item">

                        <div class="edit-category-information-label">
                            Mã danh mục
                        </div>

                        <div class="edit-category-information-value">
                            DM-@Model.DanhMucID.ToString("D4")
                        </div>

                    </div>

                    <div class="edit-category-information-item">

                        <div class="edit-category-information-label">
                            Số sản phẩm hiện có
                        </div>

                        <div class="edit-category-information-value">
                            @Model.SoSanPham sản phẩm
                        </div>

                    </div>

                </div>

                <div class="edit-category-field">

                    <label asp-for="TenDanhMuc">
                        Tên danh mục
                        <span class="edit-category-required">*</span>
                    </label>

                    <input asp-for="TenDanhMuc"
                           placeholder="Ví dụ: Trà sữa" />

                    <span asp-validation-for="TenDanhMuc"
                          class="edit-category-error">
                    </span>

                </div>

                <div class="edit-category-field">

                    <label asp-for="MoTa">
                        Mô tả danh mục
                    </label>

                    <textarea asp-for="MoTa"
                              placeholder="Nhập mô tả ngắn cho danh mục"></textarea>

                    <span asp-validation-for="MoTa"
                          class="edit-category-error">
                    </span>

                    <small class="edit-category-help">
                        Mô tả không được vượt quá 1.000 ký tự.
                    </small>

                </div>

                <div class="edit-category-field">

                    <label>
                        Trạng thái danh mục
                    </label>

                    <div class="edit-category-status">

                        <input asp-for="TrangThai"
                               type="checkbox" />

                        <label asp-for="TrangThai">
                            Danh mục đang hoạt động
                        </label>

                    </div>

                    <div class="edit-category-warning">

                        <i class="bi bi-info-circle me-1"></i>

                        Khi tạm ngưng danh mục, các sản phẩm cũ vẫn được
                        giữ nguyên. Danh mục này sẽ không xuất hiện trong
                        danh sách lựa chọn khi thêm sản phẩm mới.

                    </div>

                </div>

                <div class="edit-category-actions">

                    <button type="submit"
                            class="edit-category-submit">

                        <i class="bi bi-check-circle"></i>

                        Lưu thay đổi

                    </button>

                    <a asp-controller="QuanLyDanhMuc"
                       asp-action="Index"
                       class="edit-category-back">

                        <i class="bi bi-arrow-left"></i>

                        Quay lại

                    </a>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}